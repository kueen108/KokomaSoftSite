---
const title = 'MyTube - Global YouTube Trends';
const description = 'Explore country-by-country YouTube trending videos on an interactive globe.';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07131f" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://mytube.kokomasoft.com/" />
    <link rel="icon" type="image/png" href="/app-icons/mytube.png" />
    <link rel="apple-touch-icon" href="/app-icons/mytube.png" />
    <link rel="preconnect" href="https://i.ytimg.com" />
    <link rel="preconnect" href="https://www.youtube.com" />
    <link rel="preconnect" href="https://mytube-api.kueen108.workers.dev" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mytube.kokomasoft.com/" />
    <meta property="og:image" content="https://mytube.kokomasoft.com/app-icons/mytube.png" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main class="mytube-app">
      <header class="topbar">
        <a class="brand" href="/" aria-label="MyTube home">
          <img src="/app-icons/mytube.png" alt="" width="36" height="36" />
          <span>MyTube</span>
        </a>
        <div class="topbar-actions">
          <span class="load-status" id="loadStatus">Loading</span>
          <button class="ghost-button" id="refreshButton" type="button">Refresh</button>
        </div>
      </header>

      <section class="globe-layout" aria-label="Global YouTube trends">
        <div class="globe-stage" id="globeStage">
          <canvas id="globeCanvas" aria-label="Rotatable globe"></canvas>
          <div class="marker-layer" id="markerLayer" aria-live="polite"></div>
          <div class="globe-loading" id="globeLoading">Loading trends</div>
        </div>

        <aside class="trend-panel" aria-label="Selected country trend">
          <div class="country-heading">
            <div>
              <span class="country-kicker" id="selectedCode">KR</span>
              <h1 id="selectedCountry">South Korea</h1>
            </div>
            <button class="primary-button" id="moreButton" type="button" disabled>More</button>
          </div>

          <button class="featured-video" id="featuredVideo" type="button" disabled>
            <span class="featured-rank">#1</span>
            <img id="featuredThumb" alt="" />
            <span class="featured-copy">
              <strong id="featuredTitle">Loading</strong>
              <span id="featuredMeta">YouTube Trending</span>
            </span>
          </button>

          <div class="country-strip" id="countryStrip" aria-label="Countries"></div>
        </aside>
      </section>
    </main>

    <section class="modal" id="listModal" aria-hidden="true" aria-label="Trending videos">
      <div class="modal-backdrop" data-close-modal></div>
      <div class="modal-panel list-panel" role="dialog" aria-modal="true" aria-labelledby="listTitle">
        <header class="modal-header">
          <div>
            <span class="country-kicker" id="listCode">KR</span>
            <h2 id="listTitle">Trending Videos</h2>
          </div>
          <button class="icon-button" type="button" data-close-modal aria-label="Close">Close</button>
        </header>
        <div class="video-list" id="videoList"></div>
      </div>
    </section>

    <section class="modal" id="playerModal" aria-hidden="true" aria-label="YouTube player">
      <div class="modal-backdrop" data-close-player></div>
      <div class="modal-panel player-panel" role="dialog" aria-modal="true" aria-labelledby="playerTitle">
        <header class="modal-header">
          <div>
            <span class="country-kicker" id="playerChannel">YouTube</span>
            <h2 id="playerTitle">Video</h2>
          </div>
          <button class="icon-button" type="button" data-close-player aria-label="Close">Close</button>
        </header>
        <div class="player-frame">
          <iframe
            id="playerFrame"
            title="YouTube video player"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <div class="toast" id="toast" role="status" aria-live="polite"></div>

    <script>
      const MYTUBE_API_ORIGIN = 'https://mytube-api.kueen108.workers.dev/api';
      const API_ROOT = window.location.hostname === 'mytube.kokomasoft.com'
        ? '/api'
        : MYTUBE_API_ORIGIN;
      const CACHE_TTL = 5 * 60 * 1000;
      const GLOBE_RADIUS = 2.35;
      const MARKER_RADIUS = 2.46;
      const MAX_CONCURRENT_FETCHES = 4;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const countries = [
        { code: 'AU', flag: '🇦🇺', name: 'Australia', lat: -25.3, lon: 133.8 },
        { code: 'BR', flag: '🇧🇷', name: 'Brazil', lat: -14.2, lon: -51.9 },
        { code: 'CA', flag: '🇨🇦', name: 'Canada', lat: 56.1, lon: -106.3 },
        { code: 'CH', flag: '🇨🇭', name: 'Switzerland', lat: 46.8, lon: 8.2 },
        { code: 'DE', flag: '🇩🇪', name: 'Germany', lat: 51.2, lon: 10.4 },
        { code: 'ES', flag: '🇪🇸', name: 'Spain', lat: 40.4, lon: -3.7 },
        { code: 'FR', flag: '🇫🇷', name: 'France', lat: 46.2, lon: 2.2 },
        { code: 'GB', flag: '🇬🇧', name: 'United Kingdom', lat: 55.4, lon: -3.4 },
        { code: 'ID', flag: '🇮🇩', name: 'Indonesia', lat: -2.5, lon: 118.0 },
        { code: 'IN', flag: '🇮🇳', name: 'India', lat: 20.6, lon: 78.9 },
        { code: 'IT', flag: '🇮🇹', name: 'Italy', lat: 41.9, lon: 12.6 },
        { code: 'JP', flag: '🇯🇵', name: 'Japan', lat: 36.2, lon: 138.3 },
        { code: 'KR', flag: '🇰🇷', name: 'South Korea', lat: 36.5, lon: 127.8 },
        { code: 'MX', flag: '🇲🇽', name: 'Mexico', lat: 23.6, lon: -102.5 },
        { code: 'NL', flag: '🇳🇱', name: 'Netherlands', lat: 52.1, lon: 5.3 },
        { code: 'RU', flag: '🇷🇺', name: 'Russia', lat: 61.5, lon: 105.3 },
        { code: 'SA', flag: '🇸🇦', name: 'Saudi Arabia', lat: 23.9, lon: 45.1 },
        { code: 'TR', flag: '🇹🇷', name: 'Turkey', lat: 39.0, lon: 35.2 },
        { code: 'US', flag: '🇺🇸', name: 'United States', lat: 39.8, lon: -98.6 },
      ];

      const countryByCode = new Map(countries.map((country) => [country.code, country]));
      const videosByCountry = new Map();
      const topVideosByCountry = new Map();
      const failedCountries = new Set();
      let selectedCode = chooseDefaultCountry();
      let loadedCount = 0;
      let renderer;
      let scene;
      let camera;
      let globeGroup;
      let animationFrame = 0;
      let isDragging = false;
      let lastPointer = null;
      const targetRotation = { x: 0, y: 0 };
      let THREE;
      let geoEquirectangular;
      let geoPath;
      let feature;
      let mesh;
      let worldTopology;

      const stage = document.getElementById('globeStage');
      const canvas = document.getElementById('globeCanvas');
      const markerLayer = document.getElementById('markerLayer');
      const globeLoading = document.getElementById('globeLoading');
      const loadStatus = document.getElementById('loadStatus');
      const refreshButton = document.getElementById('refreshButton');
      const moreButton = document.getElementById('moreButton');
      const featuredVideo = document.getElementById('featuredVideo');
      const featuredThumb = document.getElementById('featuredThumb');
      const featuredTitle = document.getElementById('featuredTitle');
      const featuredMeta = document.getElementById('featuredMeta');
      const selectedCountry = document.getElementById('selectedCountry');
      const selectedCodeEl = document.getElementById('selectedCode');
      const countryStrip = document.getElementById('countryStrip');
      const listModal = document.getElementById('listModal');
      const listCode = document.getElementById('listCode');
      const listTitle = document.getElementById('listTitle');
      const videoList = document.getElementById('videoList');
      const playerModal = document.getElementById('playerModal');
      const playerFrame = document.getElementById('playerFrame');
      const playerTitle = document.getElementById('playerTitle');
      const playerChannel = document.getElementById('playerChannel');
      const toast = document.getElementById('toast');

      bootstrap();

      async function bootstrap() {
        try {
          const [threeModule, d3GeoModule, topojsonModule, worldTopologyModule] = await Promise.all([
            import('three'),
            import('d3-geo'),
            import('topojson-client'),
            import('world-atlas/countries-50m.json'),
          ]);
          THREE = threeModule;
          ({ geoEquirectangular, geoPath } = d3GeoModule);
          ({ feature, mesh } = topojsonModule);
          worldTopology = worldTopologyModule.default ?? worldTopologyModule;

          initGlobe();
          renderCountryStrip();
          selectCountry(selectedCode, { rotate: true });
          bindEvents();
          loadAllCountries();
        } catch (error) {
          console.error(error);
          globeLoading.textContent = 'Unable to load globe';
          loadStatus.textContent = 'Globe unavailable';
        }
      }

      function chooseDefaultCountry() {
        const language = navigator.language || '';
        const localeCountry = language.split('-')[1]?.toUpperCase();
        if (localeCountry && countryByCode.has(localeCountry)) {
          return localeCountry;
        }
        if (language.toLowerCase().startsWith('ko')) {
          return 'KR';
        }
        return 'US';
      }

      function bindEvents() {
        refreshButton.addEventListener('click', () => loadAllCountries({ force: true }));
        moreButton.addEventListener('click', openListModal);
        featuredVideo.addEventListener('click', () => {
          const video = topVideosByCountry.get(selectedCode);
          if (video) {
            openPlayer(video);
          }
        });

        stage.addEventListener('wheel', (event) => {
          event.preventDefault();
          targetRotation.y += event.deltaY * 0.0028;
        }, { passive: false });

        stage.addEventListener('pointerdown', (event) => {
          isDragging = true;
          lastPointer = { x: event.clientX, y: event.clientY };
          stage.setPointerCapture(event.pointerId);
          stage.classList.add('dragging');
        });

        stage.addEventListener('pointermove', (event) => {
          if (!isDragging || !lastPointer) {
            return;
          }
          const dx = event.clientX - lastPointer.x;
          const dy = event.clientY - lastPointer.y;
          targetRotation.y += dx * 0.006;
          targetRotation.x = clamp(targetRotation.x + dy * 0.004, -0.92, 0.92);
          lastPointer = { x: event.clientX, y: event.clientY };
        });

        stage.addEventListener('pointerup', (event) => {
          isDragging = false;
          lastPointer = null;
          stage.releasePointerCapture(event.pointerId);
          stage.classList.remove('dragging');
        });

        stage.addEventListener('pointercancel', () => {
          isDragging = false;
          lastPointer = null;
          stage.classList.remove('dragging');
        });

        document.querySelectorAll('[data-close-modal]').forEach((button) => {
          button.addEventListener('click', closeListModal);
        });
        document.querySelectorAll('[data-close-player]').forEach((button) => {
          button.addEventListener('click', closePlayer);
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeListModal();
            closePlayer();
          }
        });
        window.addEventListener('resize', resizeGlobe);
      }

      function initGlobe() {
        renderer = new THREE.WebGLRenderer({
          canvas,
          antialias: true,
          alpha: true,
          preserveDrawingBuffer: true,
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        scene = new THREE.Scene();
        camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
        camera.position.set(0, 0, 7.4);

        const ambient = new THREE.AmbientLight(0xbfdcff, 1.35);
        const key = new THREE.DirectionalLight(0xffffff, 2.4);
        key.position.set(-3, 4, 6);
        const rim = new THREE.DirectionalLight(0x67e8f9, 1.2);
        rim.position.set(5, -1, -3);
        scene.add(ambient, key, rim);

        globeGroup = new THREE.Group();
        globeGroup.rotation.set(0.3, -2.2, 0);
        targetRotation.x = globeGroup.rotation.x;
        targetRotation.y = globeGroup.rotation.y;

        const globeMaterial = new THREE.MeshStandardMaterial({
          map: createEarthTexture(),
          color: 0xffffff,
          roughness: 0.78,
          metalness: 0.02,
        });
        const globe = new THREE.Mesh(
          new THREE.SphereGeometry(GLOBE_RADIUS, 128, 96),
          globeMaterial,
        );
        globeGroup.add(globe);

        const atmosphere = new THREE.Mesh(
          new THREE.SphereGeometry(GLOBE_RADIUS * 1.018, 128, 96),
          new THREE.MeshBasicMaterial({
            color: 0x67e8f9,
            transparent: true,
            opacity: 0.09,
            side: THREE.BackSide,
          }),
        );
        globeGroup.add(atmosphere);
        globeGroup.add(createGridLines());
        scene.add(globeGroup);

        resizeGlobe();
        animate();
      }

      function createEarthTexture() {
        const textureCanvas = document.createElement('canvas');
        textureCanvas.width = 2048;
        textureCanvas.height = 1024;
        const ctx = textureCanvas.getContext('2d');
        const width = textureCanvas.width;
        const height = textureCanvas.height;
        const projection = geoEquirectangular()
          .translate([width / 2, height / 2])
          .scale(width / (2 * Math.PI))
          .precision(0.35);
        const path = geoPath(projection, ctx);
        const land = feature(worldTopology, worldTopology.objects.land);
        const borders = mesh(
          worldTopology,
          worldTopology.objects.countries,
          (a, b) => a !== b,
        );

        const ocean = ctx.createLinearGradient(0, 0, width, height);
        ocean.addColorStop(0, '#071d2f');
        ocean.addColorStop(0.38, '#0b3450');
        ocean.addColorStop(0.68, '#0c2d43');
        ocean.addColorStop(1, '#061421');
        ctx.fillStyle = ocean;
        ctx.fillRect(0, 0, width, height);

        drawOceanTexture(ctx, width, height);

        ctx.strokeStyle = 'rgba(125, 211, 252, 0.12)';
        ctx.lineWidth = 1;
        for (let lon = -180; lon <= 180; lon += 15) {
          const x = ((lon + 180) / 360) * width;
          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, height);
          ctx.stroke();
        }
        for (let lat = -75; lat <= 75; lat += 15) {
          const y = ((90 - lat) / 180) * height;
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(width, y);
          ctx.stroke();
        }

        const landGradient = ctx.createLinearGradient(0, 0, width, height);
        landGradient.addColorStop(0, '#5da887');
        landGradient.addColorStop(0.38, '#4f9d76');
        landGradient.addColorStop(0.72, '#2f7658');
        landGradient.addColorStop(1, '#23583f');

        ctx.save();
        ctx.beginPath();
        path(land);
        ctx.shadowColor = 'rgba(173, 255, 226, 0.26)';
        ctx.shadowBlur = 11;
        ctx.shadowOffsetX = 0;
        ctx.shadowOffsetY = 0;
        ctx.fillStyle = landGradient;
        ctx.fill();
        ctx.restore();

        ctx.save();
        ctx.beginPath();
        path(land);
        ctx.clip();
        drawLandTexture(ctx, width, height);
        ctx.restore();

        ctx.beginPath();
        path(land);
        ctx.lineWidth = 2.7;
        ctx.strokeStyle = 'rgba(190, 250, 220, 0.34)';
        ctx.stroke();

        ctx.beginPath();
        path(borders);
        ctx.lineWidth = 0.7;
        ctx.strokeStyle = 'rgba(218, 252, 235, 0.17)';
        ctx.stroke();

        const texture = new THREE.CanvasTexture(textureCanvas);
        texture.colorSpace = THREE.SRGBColorSpace;
        texture.anisotropy = 8;
        return texture;
      }

      function drawOceanTexture(ctx, width, height) {
        const rng = seededRandom(11);
        ctx.save();
        for (let i = 0; i < 150; i += 1) {
          const x = rng() * width;
          const y = rng() * height;
          const radius = 28 + rng() * 110;
          const glow = ctx.createRadialGradient(x, y, 0, x, y, radius);
          glow.addColorStop(0, `rgba(103, 232, 249, ${0.018 + rng() * 0.018})`);
          glow.addColorStop(1, 'rgba(103, 232, 249, 0)');
          ctx.fillStyle = glow;
          ctx.fillRect(x - radius, y - radius, radius * 2, radius * 2);
        }

        ctx.strokeStyle = 'rgba(125, 211, 252, 0.08)';
        ctx.lineWidth = 1;
        for (let i = 0; i < 42; i += 1) {
          const y = rng() * height;
          ctx.beginPath();
          for (let x = -80; x <= width + 80; x += 70) {
            const wave = y + Math.sin(x * 0.008 + i) * (8 + rng() * 18);
            if (x === -80) {
              ctx.moveTo(x, wave);
            } else {
              ctx.lineTo(x, wave);
            }
          }
          ctx.stroke();
        }
        ctx.restore();
      }

      function drawLandTexture(ctx, width, height) {
        const rng = seededRandom(29);
        const shade = ctx.createLinearGradient(0, 0, width, height);
        shade.addColorStop(0, 'rgba(255, 246, 188, 0.16)');
        shade.addColorStop(0.46, 'rgba(25, 84, 57, 0.04)');
        shade.addColorStop(1, 'rgba(5, 24, 21, 0.22)');
        ctx.fillStyle = shade;
        ctx.fillRect(0, 0, width, height);

        ctx.globalCompositeOperation = 'multiply';
        for (let i = 0; i < 520; i += 1) {
          const x = rng() * width;
          const y = rng() * height;
          const length = 10 + rng() * 46;
          const angle = rng() * Math.PI;
          ctx.strokeStyle = rng() > 0.48
            ? 'rgba(24, 71, 45, 0.16)'
            : 'rgba(127, 106, 53, 0.12)';
          ctx.lineWidth = 0.6 + rng() * 1.15;
          ctx.beginPath();
          ctx.moveTo(x, y);
          ctx.lineTo(x + Math.cos(angle) * length, y + Math.sin(angle) * length);
          ctx.stroke();
        }

        ctx.globalCompositeOperation = 'screen';
        for (let i = 0; i < 360; i += 1) {
          const x = rng() * width;
          const y = rng() * height;
          const radius = 2 + rng() * 10;
          ctx.fillStyle = `rgba(232, 242, 183, ${0.025 + rng() * 0.045})`;
          ctx.beginPath();
          ctx.arc(x, y, radius, 0, Math.PI * 2);
          ctx.fill();
        }

        ctx.globalCompositeOperation = 'source-over';
        ctx.strokeStyle = 'rgba(236, 255, 224, 0.08)';
        ctx.lineWidth = 0.8;
        for (let i = 0; i < 42; i += 1) {
          const y = (i / 41) * height;
          ctx.beginPath();
          ctx.moveTo(0, y);
          for (let x = 0; x <= width; x += 46) {
            ctx.lineTo(x, y + Math.sin(x * 0.014 + i * 1.7) * 7);
          }
          ctx.stroke();
        }
      }

      function seededRandom(seed) {
        let value = seed % 2147483647;
        return () => {
          value = (value * 16807) % 2147483647;
          return (value - 1) / 2147483646;
        };
      }

      function createGridLines() {
        const group = new THREE.Group();
        const material = new THREE.LineBasicMaterial({
          color: 0x8bd3ff,
          transparent: true,
          opacity: 0.16,
        });

        for (let lat = -60; lat <= 60; lat += 30) {
          const points = [];
          for (let lon = -180; lon <= 180; lon += 4) {
            points.push(latLonToVector3(lat, lon, GLOBE_RADIUS + 0.006));
          }
          group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), material));
        }

        for (let lon = -150; lon <= 180; lon += 30) {
          const points = [];
          for (let lat = -85; lat <= 85; lat += 4) {
            points.push(latLonToVector3(lat, lon, GLOBE_RADIUS + 0.006));
          }
          group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), material));
        }
        return group;
      }

      function resizeGlobe() {
        const rect = stage.getBoundingClientRect();
        const width = Math.max(320, Math.floor(rect.width));
        const height = Math.max(320, Math.floor(rect.height));
        renderer.setSize(width, height, false);
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
      }

      function animate() {
        animationFrame = requestAnimationFrame(animate);
        if (!reduceMotion && !isDragging && listModal.getAttribute('aria-hidden') === 'true' && playerModal.getAttribute('aria-hidden') === 'true') {
          targetRotation.y += 0.0009;
        }
        globeGroup.rotation.x += (targetRotation.x - globeGroup.rotation.x) * 0.08;
        globeGroup.rotation.y += (targetRotation.y - globeGroup.rotation.y) * 0.08;
        renderer.render(scene, camera);
        updateMarkerPositions();
      }

      async function loadAllCountries(options = {}) {
        const force = Boolean(options.force);
        loadedCount = 0;
        failedCountries.clear();
        refreshButton.disabled = true;
        setStatus(`Loading 0/${countries.length}`);
        globeLoading.hidden = false;
        if (force) {
          countries.forEach((country) => localStorage.removeItem(cacheKey(country.code)));
        }
        renderCountryStrip();

        const queue = [...countries];
        const workers = Array.from({ length: MAX_CONCURRENT_FETCHES }, async () => {
          while (queue.length > 0) {
            const country = queue.shift();
            await loadCountry(country, { force });
            loadedCount += 1;
            setStatus(`Loading ${loadedCount}/${countries.length}`);
          }
        });

        await Promise.all(workers);
        refreshButton.disabled = false;
        globeLoading.hidden = true;
        const loaded = countries.length - failedCountries.size;
        setStatus(failedCountries.size ? `${loaded}/${countries.length} Live` : 'Live');
        renderMarkers();
        renderCountryStrip();
        renderSelectedCountry();
        if (failedCountries.size) {
          showToast('Some countries could not load.');
        }
      }

      async function loadCountry(country, options = {}) {
        try {
          const videos = await fetchVideos(country.code, Boolean(options.force));
          videosByCountry.set(country.code, videos);
          if (videos[0]) {
            topVideosByCountry.set(country.code, videos[0]);
          }
          failedCountries.delete(country.code);
        } catch (error) {
          console.error(error);
          failedCountries.add(country.code);
        } finally {
          renderMarkers();
          renderCountryStrip();
          if (country.code === selectedCode) {
            renderSelectedCountry();
          }
        }
      }

      async function fetchVideos(code, force) {
        if (!force) {
          const cached = readCache(code);
          if (cached?.length) {
            return cached;
          }
        }

        const response = await fetchWithRetry(`${API_ROOT}/videos?regionCode=${encodeURIComponent(code)}&maxResults=50`, {
          headers: { Accept: 'application/json' },
        });
        const data = await response.json();
        const videos = (data.items || [])
          .slice(0, 50)
          .map((item, index) => normalizeVideo(item, index + 1, code))
          .filter((video) => video.id);
        writeCache(code, videos);
        return videos;
      }

      async function fetchWithRetry(url, options, attempts = 3) {
        let lastError;
        for (let attempt = 1; attempt <= attempts; attempt += 1) {
          try {
            const response = await fetch(url, options);
            if (response.ok) {
              return response;
            }
            lastError = new Error(`Request failed: ${response.status}`);
          } catch (error) {
            lastError = error;
          }

          if (attempt < attempts) {
            await delay(260 * attempt);
          }
        }
        throw lastError;
      }

      function delay(ms) {
        return new Promise((resolve) => window.setTimeout(resolve, ms));
      }

      function normalizeVideo(item, rank, countryCode) {
        const snippet = item.snippet || {};
        const thumbnails = snippet.thumbnails || {};
        const thumbnail =
          thumbnails.maxres?.url ||
          thumbnails.standard?.url ||
          thumbnails.high?.url ||
          thumbnails.medium?.url ||
          thumbnails.default?.url ||
          '';
        return {
          id: typeof item.id === 'string' ? item.id : item.id?.videoId,
          rank,
          countryCode,
          title: snippet.title || 'Untitled video',
          channelTitle: snippet.channelTitle || 'YouTube',
          thumbnail,
          publishedAt: snippet.publishedAt || '',
          viewCount: Number(item.statistics?.viewCount || 0),
        };
      }

      function cacheKey(code) {
        return `mytube:v1:videos:${code}`;
      }

      function readCache(code) {
        try {
          const raw = localStorage.getItem(cacheKey(code));
          if (!raw) {
            return null;
          }
          const cached = JSON.parse(raw);
          if (!cached.createdAt || Date.now() - cached.createdAt > CACHE_TTL) {
            return null;
          }
          return cached.videos || null;
        } catch {
          return null;
        }
      }

      function writeCache(code, videos) {
        try {
          localStorage.setItem(cacheKey(code), JSON.stringify({ createdAt: Date.now(), videos }));
        } catch {
          // Storage can be unavailable in private browsing.
        }
      }

      function renderMarkers() {
        const existing = new Set([...markerLayer.children].map((element) => element.dataset.code));
        countries.forEach((country) => {
          const video = topVideosByCountry.get(country.code);
          const marker = markerLayer.querySelector(`[data-code="${country.code}"]`);
          if (!video) {
            marker?.remove();
            return;
          }
          if (existing.has(country.code)) {
            return;
          }
          markerLayer.appendChild(createMarker(country, video));
        });
      }

      function createMarker(country, video) {
        const button = document.createElement('button');
        button.className = 'globe-marker';
        button.type = 'button';
        button.dataset.code = country.code;
        button.title = `${country.name}: ${video.title}`;

        const thumb = document.createElement('span');
        thumb.className = 'marker-thumb';
        const image = document.createElement('img');
        image.src = video.thumbnail;
        image.alt = '';
        image.loading = 'lazy';
        image.referrerPolicy = 'no-referrer';
        thumb.appendChild(image);

        const badge = document.createElement('span');
        badge.className = 'marker-badge';
        badge.textContent = country.code;

        button.append(thumb, badge);
        button.addEventListener('click', () => {
          selectCountry(country.code, { rotate: false });
          openPlayer(video);
        });
        return button;
      }

      function updateMarkerPositions() {
        if (!camera || !globeGroup) {
          return;
        }
        const rect = stage.getBoundingClientRect();
        const elements = markerLayer.querySelectorAll('.globe-marker');
        elements.forEach((element) => {
          const country = countryByCode.get(element.dataset.code);
          if (!country) {
            return;
          }
          const point = latLonToVector3(country.lat, country.lon, MARKER_RADIUS).applyQuaternion(globeGroup.quaternion);
          const projected = point.clone().project(camera);
          const visible = point.z > -0.18 && Math.abs(projected.x) < 1.25 && Math.abs(projected.y) < 1.25;
          const x = (projected.x * 0.5 + 0.5) * rect.width;
          const y = (-projected.y * 0.5 + 0.5) * rect.height;
          const scale = clamp(0.72 + (point.z / MARKER_RADIUS) * 0.28, 0.55, 1);
          element.style.transform = `translate3d(${x}px, ${y}px, 0) translate(-50%, -50%) scale(${scale})`;
          element.style.opacity = visible ? '1' : '0';
          element.style.pointerEvents = visible ? 'auto' : 'none';
          element.classList.toggle('active', element.dataset.code === selectedCode);
        });
      }

      function renderCountryStrip() {
        countryStrip.replaceChildren();
        countries.forEach((country) => {
          const button = document.createElement('button');
          button.className = 'country-chip';
          button.type = 'button';
          button.dataset.code = country.code;
          button.title = country.name;
          button.setAttribute('aria-label', `${country.name} (${country.code})`);
          button.disabled = failedCountries.has(country.code);
          button.classList.toggle('active', country.code === selectedCode);
          button.classList.toggle('loaded', topVideosByCountry.has(country.code));

          const flag = document.createElement('span');
          flag.className = 'country-flag';
          flag.setAttribute('aria-hidden', 'true');
          flag.textContent = country.flag;

          const code = document.createElement('span');
          code.className = 'country-code';
          code.textContent = country.code;

          button.append(flag, code);
          button.addEventListener('click', () => selectCountry(country.code, { rotate: true }));
          countryStrip.appendChild(button);
        });
      }

      function selectCountry(code, options = {}) {
        if (!countryByCode.has(code)) {
          return;
        }
        selectedCode = code;
        if (options.rotate) {
          rotateToCountry(countryByCode.get(code));
        }
        renderCountryStrip();
        renderSelectedCountry();
      }

      function renderSelectedCountry() {
        const country = countryByCode.get(selectedCode);
        const video = topVideosByCountry.get(selectedCode);
        selectedCodeEl.textContent = selectedCode;
        selectedCountry.textContent = country?.name || selectedCode;
        moreButton.disabled = !videosByCountry.get(selectedCode)?.length;

        if (!video) {
          featuredVideo.disabled = true;
          featuredThumb.removeAttribute('src');
          featuredTitle.textContent = failedCountries.has(selectedCode) ? 'Unavailable' : 'Loading';
          featuredMeta.textContent = failedCountries.has(selectedCode) ? 'Retry with Refresh' : 'YouTube Trending';
          return;
        }

        featuredVideo.disabled = false;
        featuredThumb.src = video.thumbnail;
        featuredThumb.alt = video.title;
        featuredTitle.textContent = video.title;
        featuredMeta.textContent = `${video.channelTitle} · ${formatViews(video.viewCount)}`;
      }

      function openListModal() {
        const country = countryByCode.get(selectedCode);
        const videos = videosByCountry.get(selectedCode) || [];
        if (!country || !videos.length) {
          showToast('No videos loaded for this country.');
          return;
        }

        listCode.textContent = selectedCode;
        listTitle.textContent = `${country.name} Top 50`;
        videoList.replaceChildren();
        videos.forEach((video) => {
          videoList.appendChild(createVideoRow(video));
        });
        listModal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modal-open');
      }

      function closeListModal() {
        listModal.setAttribute('aria-hidden', 'true');
        if (playerModal.getAttribute('aria-hidden') === 'true') {
          document.body.classList.remove('modal-open');
        }
      }

      function createVideoRow(video) {
        const button = document.createElement('button');
        button.className = 'video-row';
        button.type = 'button';

        const rank = document.createElement('span');
        rank.className = 'video-rank';
        rank.textContent = `#${video.rank}`;

        const image = document.createElement('img');
        image.src = video.thumbnail;
        image.alt = '';
        image.loading = 'lazy';
        image.referrerPolicy = 'no-referrer';

        const copy = document.createElement('span');
        copy.className = 'video-row-copy';
        const title = document.createElement('strong');
        title.textContent = video.title;
        const meta = document.createElement('span');
        meta.textContent = `${video.channelTitle} · ${formatViews(video.viewCount)}`;
        copy.append(title, meta);

        button.append(rank, image, copy);
        button.addEventListener('click', () => openPlayer(video));
        return button;
      }

      function openPlayer(video) {
        playerTitle.textContent = video.title;
        playerChannel.textContent = video.channelTitle;
        playerFrame.src = `https://www.youtube.com/embed/${encodeURIComponent(video.id)}?autoplay=1&rel=0&modestbranding=1`;
        playerModal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modal-open');
      }

      function closePlayer() {
        playerModal.setAttribute('aria-hidden', 'true');
        playerFrame.src = 'about:blank';
        if (listModal.getAttribute('aria-hidden') === 'true') {
          document.body.classList.remove('modal-open');
        }
      }

      function rotateToCountry(country) {
        const lon = THREE.MathUtils.degToRad(country.lon);
        const lat = THREE.MathUtils.degToRad(country.lat);
        targetRotation.y = -Math.PI / 2 - lon;
        targetRotation.x = clamp(lat, -0.85, 0.85);
      }

      function latLonToVector3(lat, lon, radius) {
        const phi = THREE.MathUtils.degToRad(lat);
        const theta = THREE.MathUtils.degToRad(lon);
        return new THREE.Vector3(
          radius * Math.cos(phi) * Math.cos(theta),
          radius * Math.sin(phi),
          -radius * Math.cos(phi) * Math.sin(theta),
        );
      }

      function formatViews(value) {
        if (!value) {
          return 'Views unavailable';
        }
        return `${new Intl.NumberFormat(undefined, {
          notation: 'compact',
          maximumFractionDigits: 1,
        }).format(value)} views`;
      }

      function setStatus(value) {
        loadStatus.textContent = value;
      }

      function showToast(message) {
        toast.textContent = message;
        toast.classList.add('visible');
        window.setTimeout(() => toast.classList.remove('visible'), 2600);
      }

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      window.addEventListener('pagehide', () => {
        if (animationFrame) {
          cancelAnimationFrame(animationFrame);
        }
      });
    </script>
  </body>
</html>

