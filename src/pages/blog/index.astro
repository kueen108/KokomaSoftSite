---
import Layout from '../../layouts/Layout.astro';
import { blogCategoryMeta, getBlogPostCategory, getBlogPostSlug, getMediumDigestPosts, type BlogCategory } from '../../lib/blog';

const posts = await getMediumDigestPosts();
const categories: BlogCategory[] = ['knowledge', 'ai'];
const postsByCategory = Object.fromEntries(
  categories.map((category) => [
    category,
    posts.filter((post) => getBlogPostCategory(post) === category),
  ]),
) as Record<BlogCategory, typeof posts>;
const featuredPosts = categories
  .map((category) => postsByCategory[category][0])
  .filter(Boolean);
const recentPostsByCategory = Object.fromEntries(
  categories.map((category) => [category, postsByCategory[category].slice(0, 6)]),
) as Record<BlogCategory, typeof posts>;
const monthFormatter = new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long' });
const archiveMonths = Array.from(
  posts.reduce((months, post) => {
    const date = new Date(post.data.pubDate);
    const monthKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
    const monthPosts = months.get(monthKey) ?? [];
    monthPosts.push(post);
    months.set(monthKey, monthPosts);
    return months;
  }, new Map<string, typeof posts>()),
).map(([monthKey, monthPosts]) => ({
  monthKey,
  label: monthFormatter.format(new Date(`${monthKey}-01T00:00:00+09:00`)),
  posts: monthPosts,
}));
const title = 'KokomaSoft Blog | 오늘의 지식과 AI 글';
const description = '매일 아침 엄선한 오늘의 지식과 AI, Claude Code, Codex, OpenClaw 관련 글을 한국어로 정리합니다.';
---

<Layout
  lang="ko"
  title={title}
  description={description}
  canonicalPath="https://blog.kokomasoft.com/"
  xDefaultPath="https://blog.kokomasoft.com/"
  headerHref="https://www.kokomasoft.com/"
  headerNavBaseHref="https://www.kokomasoft.com"
  ogType="website"
>
  <section class="blog-hero">
    <div class="container">
      <p class="eyebrow">Daily Briefing Blog</p>
      <h1>오늘의 지식과 AI 글</h1>
      <p class="lead">매일 아침 8시에는 현대의 지적인 사람이 알아두면 좋은 지식 한 가지를, 9시에는 AI 흐름에서 읽을 가치가 큰 글 하나를 골라 한국어로 정리합니다.</p>
    </div>
  </section>

  <section class="post-list">
    <div class="container">
      {posts.length === 0 ? (
        <article class="empty-card">
          <h2>아직 게시된 글이 없습니다</h2>
          <p>첫 자동 발행이 끝나면 여기에 매일 글이 쌓입니다.</p>
        </article>
      ) : (
        <>
          <section class="today-section" aria-labelledby="today-posts">
            <div class="section-heading">
              <p class="category-eyebrow">Start Here</p>
              <h2 id="today-posts">오늘 먼저 읽을 글</h2>
              <p>최신 글만 위에 크게 올려두고, 오래된 글은 아래 탭과 아카이브에서 찾도록 정리했습니다.</p>
            </div>

            <div class="featured-grid">
              {featuredPosts.map((post) => {
                const category = getBlogPostCategory(post);
                const meta = blogCategoryMeta[category];
                return (
                  <a class={`featured-card ${category}`} href={`${getBlogPostSlug(post)}/`}>
                    <span class="badge">{meta.label}</span>
                    <p class="date">{new Date(post.data.pubDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                    <h3>{post.data.title}</h3>
                    <p class="description">{post.data.description}</p>
                  </a>
                );
              })}
            </div>
          </section>

          <section class="browse-section" aria-labelledby="browse-posts">
            <div class="section-heading compact-heading">
              <div>
                <p class="category-eyebrow">Browse</p>
                <h2 id="browse-posts">분류별 최신 글</h2>
              </div>
              <div class="tabs" role="tablist" aria-label="블로그 분류">
                <button class="tab active" type="button" data-tab="all" aria-selected="true">전체</button>
                {categories.map((category) => <button class="tab" type="button" data-tab={category}>{blogCategoryMeta[category].label}</button>)}
              </div>
            </div>

            <div class="tab-panels">
              <div class="tab-panel active" data-panel="all">
                <div class="posts-grid compact-grid">
                  {posts.slice(0, 8).map((post) => {
                    const category = getBlogPostCategory(post);
                    return (
                      <a class="post-card compact-card" href={`${getBlogPostSlug(post)}/`}>
                        <span class="mini-badge">{blogCategoryMeta[category].label}</span>
                        <p class="date">{new Date(post.data.pubDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                        <h3>{post.data.title}</h3>
                        <p class="description">{post.data.description}</p>
                      </a>
                    );
                  })}
                </div>
              </div>

              {categories.map((category) => {
                const categoryPosts = recentPostsByCategory[category];
                const meta = blogCategoryMeta[category];
                return (
                  <div class="tab-panel" data-panel={category}>
                    <div class="category-note">
                      <p>{meta.description}</p>
                      <span class="count">총 {postsByCategory[category].length}개</span>
                    </div>
                    {categoryPosts.length ? (
                      <div class="posts-grid compact-grid">
                        {categoryPosts.map((post) => (
                          <a class="post-card compact-card" href={`${getBlogPostSlug(post)}/`}>
                            <p class="date">{new Date(post.data.pubDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                            <h3>{post.data.title}</h3>
                            <p class="description">{post.data.description}</p>
                            <div class="source">
                              <span>{category === 'knowledge' ? '참고' : '원문'}</span>
                              <span class="source-title">{post.data.sourceTitle}</span>
                            </div>
                          </a>
                        ))}
                      </div>
                    ) : (
                      <article class="empty-card compact">
                        <p>아직 이 분류의 글이 없습니다.</p>
                      </article>
                    )}
                  </div>
                );
              })}
            </div>
          </section>

          <section class="archive-section" aria-labelledby="archive-posts">
            <div class="section-heading compact-heading">
              <div>
                <p class="category-eyebrow">Archive</p>
                <h2 id="archive-posts">월별 아카이브</h2>
                <p>스크롤이 길어지지 않도록 지난 글은 월별로 접어두었습니다.</p>
              </div>
            </div>

            <div class="archive-list">
              {archiveMonths.map((month, index) => (
                <details class="archive-month" open={index === 0}>
                  <summary>
                    <span>{month.label}</span>
                    <span>{month.posts.length}개</span>
                  </summary>
                  <ul>
                    {month.posts.map((post) => {
                      const category = getBlogPostCategory(post);
                      return (
                        <li>
                          <a href={`${getBlogPostSlug(post)}/`}>
                            <span class="archive-category">{blogCategoryMeta[category].label}</span>
                            <span>{post.data.title}</span>
                            <time datetime={post.data.pubDate}>{new Date(post.data.pubDate).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' })}</time>
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </details>
              ))}
            </div>
          </section>
        </>
      )}
    </div>
  </section>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((item) => {
        const isActive = item === tab;
        item.classList.toggle('active', isActive);
        item.setAttribute('aria-selected', String(isActive));
      });
      panels.forEach((panel) => panel.classList.toggle('active', panel.dataset.panel === target));
    });
  });
</script>

<style>
  .blog-hero {
    padding: 5.5rem 0 4rem;
    color: white;
    background: radial-gradient(circle at top right, rgba(20, 184, 166, 0.38), transparent 34%), linear-gradient(135deg, #101827, #172033 58%, #0f766e);
  }

  .eyebrow {
    color: #99f6e4;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  h1 {
    max-width: 820px;
    font-size: clamp(2.6rem, 7vw, 5.2rem);
    line-height: 0.98;
    margin-bottom: 1rem;
  }

  .lead {
    max-width: 760px;
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .post-list {
    padding: 3rem 0 5rem;
  }

  .today-section,
  .browse-section,
  .archive-section {
    display: grid;
    gap: 1rem;
  }

  .browse-section,
  .archive-section {
    margin-top: 3rem;
  }

  .section-heading {
    max-width: 820px;
  }

  .section-heading h2 {
    color: var(--color-ink);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    margin-bottom: 0.45rem;
  }

  .section-heading p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .compact-heading {
    max-width: none;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-end;
  }

  .category-eyebrow {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .featured-card,
  .post-card,
  .empty-card {
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: var(--color-surface);
    box-shadow: 0 14px 42px rgba(15, 23, 42, 0.06);
  }

  .featured-card,
  .post-card {
    display: block;
    color: inherit;
    text-decoration: none;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }

  .featured-card {
    position: relative;
    overflow: hidden;
    padding: 1.65rem;
    min-height: 260px;
  }

  .featured-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.08;
    background: radial-gradient(circle at top right, var(--color-primary), transparent 42%);
    pointer-events: none;
  }

  .featured-card:hover,
  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.1);
  }

  .badge,
  .mini-badge,
  .archive-category,
  .count {
    display: inline-flex;
    width: fit-content;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 850;
  }

  .badge {
    padding: 0.38rem 0.72rem;
    background: var(--color-primary);
    color: white;
    margin-bottom: 1rem;
  }

  .mini-badge,
  .archive-category,
  .count {
    padding: 0.25rem 0.55rem;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .date {
    color: var(--color-primary);
    font-size: 0.86rem;
    font-weight: 800;
    margin-bottom: 0.45rem;
  }

  .featured-card h3,
  .post-card h3 {
    color: var(--color-ink);
    line-height: 1.25;
    margin-bottom: 0.65rem;
  }

  .featured-card h3 {
    font-size: clamp(1.45rem, 3vw, 2.1rem);
  }

  .post-card h3 {
    font-size: 1.12rem;
  }

  .featured-card:hover h3,
  .post-card:hover h3 {
    color: var(--color-primary);
  }

  .description {
    color: var(--color-text);
    line-height: 1.75;
  }

  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: flex-end;
  }

  .tab {
    cursor: pointer;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.6rem 0.9rem;
    background: var(--color-surface);
    color: var(--color-text-muted);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 850;
  }

  .tab.active,
  .tab:hover {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: white;
  }

  .tab-panel {
    display: none;
  }

  .tab-panel.active {
    display: block;
  }

  .category-note {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .posts-grid {
    display: grid;
    gap: 0.85rem;
  }

  .compact-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .post-card,
  .empty-card {
    padding: 1.15rem;
  }

  .compact-card .description {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.8rem;
  }

  .source {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .source-title {
    color: var(--color-primary);
    font-weight: 700;
  }

  .empty-card.compact {
    box-shadow: none;
  }

  .archive-list {
    display: grid;
    gap: 0.75rem;
  }

  .archive-month {
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: var(--color-surface);
    overflow: hidden;
  }

  .archive-month summary {
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.15rem;
    color: var(--color-ink);
    font-weight: 900;
  }

  .archive-month ul {
    display: grid;
    gap: 0;
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .archive-month li + li {
    border-top: 1px solid var(--color-border);
  }

  .archive-month a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.9rem 1.15rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .archive-month a:hover {
    color: var(--color-primary);
    background: var(--color-bg-alt);
  }

  .archive-month time {
    color: var(--color-text-muted);
    font-size: 0.86rem;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .featured-grid,
    .compact-grid {
      grid-template-columns: 1fr;
    }

    .compact-heading,
    .category-note {
      display: grid;
      justify-content: stretch;
    }

    .tabs {
      justify-content: flex-start;
    }

    .archive-month a {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
