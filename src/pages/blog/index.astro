---
import Layout from '../../layouts/Layout.astro';
import { blogCategoryMeta, getBlogPostCategory, getBlogPostSlug, getMediumDigestPosts, type BlogCategory } from '../../lib/blog';

const posts = await getMediumDigestPosts();
const categories: BlogCategory[] = ['knowledge', 'ai'];
const postsByCategory = Object.fromEntries(
  categories.map((category) => [
    category,
    posts.filter((post) => getBlogPostCategory(post) === category),
  ]),
) as Record<BlogCategory, typeof posts>;
const title = 'KokomaSoft Blog | 오늘의 지식과 AI 글';
const description = '매일 아침 엄선한 오늘의 지식과 AI, Claude Code, Codex, OpenClaw 관련 글을 한국어로 정리합니다.';
---

<Layout
  lang="ko"
  title={title}
  description={description}
  canonicalPath="https://blog.kokomasoft.com/"
  xDefaultPath="https://blog.kokomasoft.com/"
  headerHref="https://www.kokomasoft.com/"
  headerNavBaseHref="https://www.kokomasoft.com"
  ogType="website"
>
  <section class="blog-hero">
    <div class="container">
      <p class="eyebrow">Daily Briefing Blog</p>
      <h1>오늘의 지식과 AI 글</h1>
      <p class="lead">매일 아침 8시에는 현대의 지적인 사람이 알아두면 좋은 지식 한 가지를, 9시에는 AI 흐름에서 읽을 가치가 큰 글 하나를 골라 한국어로 정리합니다.</p>
    </div>
  </section>

  <section class="post-list">
    <div class="container">
      {posts.length === 0 ? (
        <article class="empty-card">
          <h2>아직 게시된 글이 없습니다</h2>
          <p>첫 자동 발행이 끝나면 여기에 매일 글이 쌓입니다.</p>
        </article>
      ) : (
        <div class="category-sections">
          {categories.map((category) => {
            const categoryPosts = postsByCategory[category];
            const meta = blogCategoryMeta[category];
            return (
              <section class="category-section" aria-labelledby={`category-${category}`}>
                <div class="category-heading">
                  <div>
                    <p class="category-eyebrow">{meta.eyebrow}</p>
                    <h2 id={`category-${category}`}>{meta.label}</h2>
                    <p>{meta.description}</p>
                  </div>
                  <span class="count">{categoryPosts.length}개</span>
                </div>

                {categoryPosts.length ? (
                  <div class="posts-grid">
                    {categoryPosts.map((post) => (
                      <a class="post-card" href={`${getBlogPostSlug(post)}/`}>
                        <p class="date">{new Date(post.data.pubDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                        <h3>{post.data.title}</h3>
                        <p class="description">{post.data.description}</p>
                        <div class="source">
                          <span>{category === 'knowledge' ? '참고' : '원문'}</span>
                          <span class="source-title">{post.data.sourceTitle}</span>
                        </div>
                        {post.data.tags?.length ? (
                          <ul class="tags">
                            {post.data.tags.map((tag) => <li>{tag}</li>)}
                          </ul>
                        ) : null}
                      </a>
                    ))}
                  </div>
                ) : (
                  <article class="empty-card compact">
                    <p>아직 이 분류의 글이 없습니다.</p>
                  </article>
                )}
              </section>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-hero {
    padding: 5.5rem 0 4rem;
    color: white;
    background: radial-gradient(circle at top right, rgba(20, 184, 166, 0.38), transparent 34%), linear-gradient(135deg, #101827, #172033 58%, #0f766e);
  }

  .eyebrow {
    color: #99f6e4;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  h1 {
    max-width: 820px;
    font-size: clamp(2.6rem, 7vw, 5.2rem);
    line-height: 0.98;
    margin-bottom: 1rem;
  }

  .lead {
    max-width: 760px;
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .post-list {
    padding: 3rem 0 5rem;
  }

  .category-sections {
    display: grid;
    gap: 2.5rem;
  }

  .category-section {
    display: grid;
    gap: 1rem;
  }

  .category-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
  }

  .category-eyebrow {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .category-heading h2 {
    color: var(--color-ink);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin-bottom: 0.35rem;
  }

  .category-heading p {
    max-width: 760px;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .count {
    flex: 0 0 auto;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .posts-grid {
    display: grid;
    gap: 1rem;
  }

  .post-card,
  .empty-card {
    padding: 1.4rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-surface);
    box-shadow: 0 14px 42px rgba(15, 23, 42, 0.06);
  }

  .date {
    color: var(--color-primary);
    font-size: 0.86rem;
    font-weight: 800;
    margin-bottom: 0.45rem;
  }

  .post-card h3 {
    font-size: clamp(1.35rem, 3vw, 2rem);
    line-height: 1.25;
    margin-bottom: 0.65rem;
  }

  .post-card {
    display: block;
    color: inherit;
    text-decoration: none;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.1);
  }

  .post-card h3 {
    color: var(--color-ink);
  }

  .post-card:hover h3 {
    color: var(--color-primary);
  }

  .description {
    color: var(--color-text);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .source {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }

  .source-title {
    color: var(--color-primary);
    font-weight: 700;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1rem;
    list-style: none;
  }

  .empty-card.compact {
    box-shadow: none;
  }

  .empty-card.compact p {
    color: var(--color-text-muted);
  }

  .tags li {
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .category-heading {
      display: grid;
    }

    .count {
      width: fit-content;
    }
  }
</style>
