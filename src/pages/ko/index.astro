---
import Layout from '../../layouts/Layout.astro';
import HomePage from '../../components/HomePage.astro';
import { apps } from '../../i18n/apps';
import {
  appItemListSchema,
  homeAlternates,
  homeDescription,
  homeTitle,
  organizationSchema,
  websiteSchema,
} from '../../lib/seo';
---

<Layout
  lang="ko"
  title={homeTitle('ko')}
  description={homeDescription('ko')}
  canonicalPath="/ko/"
  alternates={homeAlternates()}
  xDefaultPath="/"
  image="/app-icons/ungyeol.png"
  structuredData={[organizationSchema('ko'), websiteSchema('ko'), appItemListSchema(apps, 'ko')]}
  theme="dark"
>
  <HomePage lang="ko" />
</Layout>
