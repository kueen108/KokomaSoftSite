---
import Layout from '../../layouts/Layout.astro';
import HomePage from '../../components/HomePage.astro';
import {
  homeAlternates,
  homeDescription,
  homeTitle,
  organizationSchema,
  websiteSchema,
} from '../../lib/seo';
---

<Layout
  lang="ko"
  title={homeTitle('ko')}
  description={homeDescription('ko')}
  canonicalPath="/ko/"
  alternates={homeAlternates()}
  xDefaultPath="/"
  image="/app-icons/ungyeol.png"
  structuredData={[organizationSchema('ko'), websiteSchema('ko')]}
>
  <HomePage lang="ko" />
</Layout>
