---
import AppDetail from '../../../components/AppDetail.astro';
import Layout from '../../../layouts/Layout.astro';
import { apps, type AppInfo } from '../../../i18n/apps';
import { languages, t, type Lang } from '../../../i18n/translations';
import {
  appAlternates,
  appTitle,
  breadcrumbSchema,
  mobileApplicationSchema,
} from '../../../lib/seo';

interface Props {
  app: AppInfo;
  lang: Lang;
}

export function getStaticPaths() {
  return Object.keys(languages).flatMap((lang) =>
    apps.map((app) => ({
      params: { lang, appId: app.id },
      props: { app, lang },
    })),
  );
}

const { app, lang } = Astro.props;
const tr = t(lang);
// Footer shows this app's own legal links instead of the SnsPublisher defaults
const appFooterLinks = [
  ...(app.hasTermsPage ? [{ href: `/${lang}/terms/${app.id}/`, label: tr.termsOfService }] : []),
  { href: `/${lang}/privacy/${app.id}/`, label: tr.privacyPolicy },
];
---

<Layout
  theme="dark"
  footerLinks={appFooterLinks}
  lang={lang}
  title={appTitle(app, lang)}
  description={app.description[lang]}
  canonicalPath={`/${lang}/apps/${app.id}/`}
  alternates={appAlternates(app.id)}
  xDefaultPath={`/ko/apps/${app.id}/`}
  image={app.iconUrl}
  structuredData={[
    mobileApplicationSchema(app, lang),
    breadcrumbSchema([
      { name: 'KokomaSoft', path: `/${lang}/` },
      { name: app.name[lang], path: `/${lang}/apps/${app.id}/` },
    ]),
  ]}
>
  <AppDetail app={app} lang={lang} />
</Layout>
