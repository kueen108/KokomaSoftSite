---
import Layout from '../../../layouts/Layout.astro';
import AccountDeletion from '../../../components/AccountDeletion.astro';
import {
  accountDeletionAlternates,
  accountDeletionDescription,
  accountDeletionTitle,
} from '../../../lib/seo';

const appId = 'onul';
const appName = 'Onul';
---

<Layout
  lang="en"
  title={accountDeletionTitle(appName, 'en')}
  description={accountDeletionDescription(appName, 'en')}
  canonicalPath="/en/account-deletion/onul/"
  alternates={accountDeletionAlternates(appId)}
  xDefaultPath="/ko/account-deletion/onul/"
>
  <AccountDeletion lang="en" appName={appName} />
</Layout>
