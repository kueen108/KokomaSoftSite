---
import Layout from '../../layouts/Layout.astro';
import HomePage from '../../components/HomePage.astro';
import {
  homeAlternates,
  homeDescription,
  homeTitle,
  organizationSchema,
  websiteSchema,
} from '../../lib/seo';
---

<Layout
  lang="en"
  title={homeTitle('en')}
  description={homeDescription('en')}
  canonicalPath="/en/"
  alternates={homeAlternates()}
  xDefaultPath="/"
  image="/app-icons/ungyeol.png"
  structuredData={[organizationSchema('en'), websiteSchema('en')]}
  theme="dark"
>
  <HomePage lang="en" />
</Layout>
