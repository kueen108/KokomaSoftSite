---
import Layout from '../../../layouts/Layout.astro';
import PrivacyPolicy from '../../../components/PrivacyPolicy.astro';
import { privacyAlternates, privacyDescription, privacyTitle } from '../../../lib/seo';

const appId = 'glowup';
const appName = 'GlowUp';
---
<Layout
  lang="en"
  title={privacyTitle(appName, 'en')}
  description={privacyDescription(appName, 'en')}
  canonicalPath="/en/privacy/glowup/"
  alternates={privacyAlternates(appId)}
  xDefaultPath="/ko/privacy/glowup/"
>
  <PrivacyPolicy lang="en" appName={appName} appId={appId} />
</Layout>
