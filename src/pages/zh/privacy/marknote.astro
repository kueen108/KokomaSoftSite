---
import Layout from '../../../layouts/Layout.astro';
import PrivacyPolicy from '../../../components/PrivacyPolicy.astro';
import { privacyAlternates, privacyDescription, privacyTitle } from '../../../lib/seo';

const appId = 'marknote';
const appName = 'MarkNote';
---
<Layout
  lang="zh"
  title={privacyTitle(appName, 'zh')}
  description={privacyDescription(appName, 'zh')}
  canonicalPath="/zh/privacy/marknote/"
  alternates={privacyAlternates(appId)}
  xDefaultPath="/ko/privacy/marknote/"
>
  <PrivacyPolicy lang="zh" appName={appName} appId={appId} />
</Layout>
