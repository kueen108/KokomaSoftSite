---
import Layout from '../../layouts/Layout.astro';
import HomePage from '../../components/HomePage.astro';
import {
  homeAlternates,
  homeDescription,
  homeTitle,
  organizationSchema,
  websiteSchema,
} from '../../lib/seo';
---

<Layout
  lang="zh"
  title={homeTitle('zh')}
  description={homeDescription('zh')}
  canonicalPath="/zh/"
  alternates={homeAlternates()}
  xDefaultPath="/"
  image="/app-icons/ungyeol.png"
  structuredData={[organizationSchema('zh'), websiteSchema('zh')]}
  theme="dark"
>
  <HomePage lang="zh" />
</Layout>
