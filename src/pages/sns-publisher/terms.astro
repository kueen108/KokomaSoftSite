---
import Layout from '../../layouts/Layout.astro';

const appName = 'SnsPublisher';
const appIcon = '/app-icons/sns-publisher.png';
const title = `${appName} Terms of Service`;
const description =
  'Terms of Service for SnsPublisher, KokomaSoft social content publishing support service.';
---

<Layout
  lang="en"
  title={title}
  description={description}
  canonicalPath="/sns-publisher/terms/"
  xDefaultPath="/sns-publisher/terms/"
  image={appIcon}
  favicon={appIcon}
  headerBrandName={appName}
  headerIcon={appIcon}
  headerHref="/sns-publisher/"
  ogType="article"
>
  <section class="legal-page">
    <div class="container">
      <div class="legal-brand">
        <img src={appIcon} alt="SnsPublisher app icon" width="76" height="76" />
        <div>
          <p class="eyebrow">SnsPublisher Legal</p>
          <h1>SnsPublisher Terms of Service</h1>
        </div>
      </div>
      <p class="last-updated">Last updated: May 18, 2026</p>
      <p class="intro">
        These Terms of Service apply to SnsPublisher, a KokomaSoft service that helps authorized users prepare, manage, and publish short-form promotional content to connected creator accounts.
        By using SnsPublisher, you agree to these terms and any additional terms shown in the service.
      </p>

      <article class="legal-section">
        <h2>1. Service Scope</h2>
        <p>
          SnsPublisher may provide tools for preparing media, reviewing captions and metadata, connecting authorized creator accounts, and requesting publication through supported third-party developer APIs. Available features may vary by account, platform, region, and approval status.
        </p>
      </article>

      <article class="legal-section">
        <h2>2. Your Responsibilities</h2>
        <p>
          You are responsible for the content you create, upload, share, or submit through SnsPublisher. You must have all rights and permissions required for your content, and you must not use the service to violate laws, third-party rights, platform rules, or community standards.
        </p>
      </article>

      <article class="legal-section">
        <h2>3. Authorized Accounts and Platform Rules</h2>
        <p>
          If a feature requires third-party authorization, you may need to sign in to the relevant account and grant the requested permissions. Your use of each connected platform remains subject to that platform's terms, community guidelines, privacy policy, and developer requirements.
        </p>
      </article>

      <article class="legal-section">
        <h2>4. Content Rights</h2>
        <p>
          You retain ownership of content you create. When you use SnsPublisher to process, preview, transmit, or publish content, you grant KokomaSoft the limited rights needed to provide that feature, including preparing, transmitting, and displaying the content as requested by you.
        </p>
      </article>

      <article class="legal-section">
        <h2>5. Prohibited Use</h2>
        <p>
          You may not misuse SnsPublisher, attempt unauthorized access, interfere with service operations, submit misleading or harmful content, scrape or harvest data without permission, or use the service for spam, impersonation, infringement, harassment, illegal activity, or security abuse.
        </p>
      </article>

      <article class="legal-section">
        <h2>6. Availability and Changes</h2>
        <p>
          KokomaSoft may update, suspend, or discontinue SnsPublisher features at any time, including when platform requirements, API availability, app review status, or security considerations change. We may also update these terms by posting a revised version on this page.
        </p>
      </article>

      <article class="legal-section">
        <h2>7. Disclaimer</h2>
        <p>
          SnsPublisher is provided on an "as is" and "as available" basis. To the maximum extent permitted by law, KokomaSoft disclaims warranties of uninterrupted availability, error-free operation, fitness for a particular purpose, and non-infringement.
        </p>
      </article>

      <article class="legal-section">
        <h2>8. Limitation of Liability</h2>
        <p>
          To the maximum extent permitted by law, KokomaSoft will not be liable for indirect, incidental, consequential, special, punitive, or exemplary damages, or for loss of data, content, profits, goodwill, or business opportunities arising from your use of SnsPublisher.
        </p>
      </article>

      <article class="legal-section">
        <h2>9. Contact</h2>
        <p>
          For questions about these terms, contact KokomaSoft at <a href="mailto:kokomasoft@gmail.com">kokomasoft@gmail.com</a>.
        </p>
      </article>
    </div>
  </section>
</Layout>

<style>
  .legal-page {
    padding: 5rem 0;
    background: var(--color-bg);
  }

  .legal-page .container {
    max-width: 820px;
  }

  .eyebrow {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
    margin-bottom: 0.65rem;
  }

  .legal-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .legal-brand img {
    width: 76px;
    height: 76px;
    border-radius: 18px;
    box-shadow: 0 16px 36px rgba(15, 23, 42, 0.16);
  }

  .legal-brand .eyebrow {
    margin-bottom: 0.35rem;
  }

  h1 {
    color: var(--color-ink);
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }

  .last-updated {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .intro,
  .legal-section p {
    color: var(--color-text);
    line-height: 1.82;
  }

  .intro {
    margin-bottom: 2.25rem;
  }

  .legal-section {
    padding-top: 1.4rem;
    margin-top: 1.4rem;
    border-top: 1px solid var(--color-border);
  }

  .legal-section h2 {
    color: var(--color-ink);
    font-size: 1.15rem;
    margin-bottom: 0.65rem;
  }

  .legal-section a {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }

  .legal-section a:hover {
    text-decoration: underline;
  }

  @media (max-width: 560px) {
    .legal-brand {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
