---
import Layout from '../../layouts/Layout.astro';

const appName = 'SnsPublisher';
const appIcon = '/app-icons/sns-publisher.png';
const title = appName;
const description =
  'SnsPublisher helps authorized teams prepare and publish short-form promotional videos to creator accounts.';
---

<Layout
  lang="en"
  title={title}
  description={description}
  canonicalPath="/sns-publisher/"
  xDefaultPath="/sns-publisher/"
  image={appIcon}
  favicon={appIcon}
  headerBrandName={appName}
  headerIcon={appIcon}
  headerHref="/sns-publisher/"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: appName,
    provider: {
      '@type': 'Organization',
      name: 'KokomaSoft',
      url: 'https://kokomasoft.com/',
    },
    serviceType: 'Social content publishing support',
    url: 'https://kokomasoft.com/sns-publisher/',
    image: 'https://kokomasoft.com/app-icons/sns-publisher.png',
    description,
  }}
>
  <section class="service-hero">
    <div class="container service-hero-grid">
      <div class="service-copy">
        <div class="app-identity">
          <img src={appIcon} alt="SnsPublisher app icon" width="88" height="88" />
          <p class="eyebrow">KokomaSoft Service</p>
        </div>
        <h1>SnsPublisher</h1>
        <p class="lead">
          SnsPublisher supports KokomaSoft's content operations by helping authorized users prepare captions, organize media, and publish short-form promotional videos to approved creator accounts.
        </p>
        <div class="legal-links" aria-label="SnsPublisher legal links">
          <a href="/sns-publisher/terms/">Terms of Service</a>
          <a href="/sns-publisher/privacy/">Privacy Policy</a>
        </div>
      </div>
      <div class="service-panel" aria-label="SnsPublisher workflow summary">
        <div>
          <span class="panel-label">Workflow</span>
          <strong>Prepare</strong>
          <p>Review media, captions, and metadata before a publishing action.</p>
        </div>
        <div>
          <span class="panel-label">Authorization</span>
          <strong>User controlled</strong>
          <p>Publishing is performed only for accounts that have granted the required permissions.</p>
        </div>
        <div>
          <span class="panel-label">Support</span>
          <strong>KokomaSoft</strong>
          <p>Service questions and privacy requests are handled through our support email.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="service-section">
    <div class="container section-grid">
      <div>
        <p class="eyebrow">Service Details</p>
        <h2>Built for organized social publishing</h2>
      </div>
      <div class="detail-list">
        <article>
          <h3>Content preparation</h3>
          <p>
            Users can collect short-form video assets, prepare captions, and review publishing details before content is sent to a connected creator account.
          </p>
        </article>
        <article>
          <h3>Sandbox review flow</h3>
          <p>
            The current production request is limited to OAuth authorization, creator account access, and inbox upload using the <code>user.info.basic</code> and <code>video.upload</code> scopes. Direct publishing is not part of this request.
          </p>
        </article>
        <article>
          <h3>Operational records</h3>
          <p>
            KokomaSoft may keep limited logs needed to operate the service, troubleshoot publishing requests, maintain security, and respond to support inquiries.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="service-section muted">
    <div class="container contact-band">
      <div>
        <p class="eyebrow">Contact</p>
        <h2>Questions about SnsPublisher</h2>
        <p>
          For service, legal, privacy, or data deletion questions, contact KokomaSoft support.
        </p>
      </div>
      <a class="contact-link" href="mailto:kokomasoft@gmail.com">kokomasoft@gmail.com</a>
    </div>
  </section>
</Layout>

<style>
  .service-hero {
    padding: 5.5rem 0 4rem;
    background: linear-gradient(135deg, #f6f7f2 0%, #e7f0ee 52%, #f2efe7 100%);
  }

  .service-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 3rem;
    align-items: center;
  }

  .eyebrow {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
    margin-bottom: 0.7rem;
  }

  .app-identity {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .app-identity img {
    width: 88px;
    height: 88px;
    border-radius: 20px;
    box-shadow: 0 18px 42px rgba(15, 23, 42, 0.18);
  }

  .app-identity .eyebrow {
    margin-bottom: 0;
  }

  h1,
  h2,
  h3 {
    color: var(--color-ink);
  }

  h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    margin-bottom: 1.25rem;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .lead {
    max-width: 700px;
    color: var(--color-text);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.75;
  }

  .legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .legal-links a,
  .contact-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background: var(--color-ink);
    color: white;
    font-weight: 700;
    text-decoration: none;
  }

  .legal-links a:nth-child(2) {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-border);
  }

  .service-panel {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-soft);
  }

  .service-panel div {
    padding: 1rem;
    border-radius: 8px;
    background: white;
  }

  .panel-label {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .service-panel strong {
    display: block;
    color: var(--color-ink);
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .service-panel p,
  .detail-list p,
  .contact-band p {
    color: var(--color-text);
    line-height: 1.72;
  }

  code {
    padding: 0.1rem 0.3rem;
    border-radius: 5px;
    background: rgba(15, 23, 42, 0.08);
    color: var(--color-ink);
    font-size: 0.92em;
  }

  .service-section {
    padding: 4.5rem 0;
    background: var(--color-bg);
  }

  .service-section.muted {
    background: var(--color-bg-alt);
  }

  .section-grid {
    display: grid;
    grid-template-columns: minmax(220px, 0.75fr) minmax(0, 1.25fr);
    gap: 3rem;
  }

  .detail-list {
    display: grid;
    gap: 1.25rem;
  }

  .detail-list article {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .detail-list h3 {
    font-size: 1.12rem;
    margin-bottom: 0.45rem;
  }

  .contact-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .contact-band > div {
    max-width: 680px;
  }

  .contact-link {
    flex: 0 0 auto;
    background: var(--color-primary);
  }

  @media (max-width: 820px) {
    .service-hero-grid,
    .section-grid {
      grid-template-columns: 1fr;
    }

    .service-hero {
      padding-top: 4rem;
    }

    .contact-band {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
