---
import Layout from '../../layouts/Layout.astro';
import HomePage from '../../components/HomePage.astro';
import { apps } from '../../i18n/apps';
import {
  appItemListSchema,
  homeAlternates,
  homeDescription,
  homeTitle,
  organizationSchema,
  websiteSchema,
} from '../../lib/seo';
---

<Layout
  lang="ja"
  title={homeTitle('ja')}
  description={homeDescription('ja')}
  canonicalPath="/ja/"
  alternates={homeAlternates()}
  xDefaultPath="/"
  image="/app-icons/ungyeol.png"
  structuredData={[organizationSchema('ja'), websiteSchema('ja'), appItemListSchema(apps, 'ja')]}
  theme="dark"
>
  <HomePage lang="ja" />
</Layout>
