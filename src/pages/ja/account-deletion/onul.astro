---
import Layout from '../../../layouts/Layout.astro';
import AccountDeletion from '../../../components/AccountDeletion.astro';
import {
  accountDeletionAlternates,
  accountDeletionDescription,
  accountDeletionTitle,
} from '../../../lib/seo';

const appId = 'onul';
const appName = 'Onul';
---

<Layout
  lang="ja"
  title={accountDeletionTitle(appName, 'ja')}
  description={accountDeletionDescription(appName, 'ja')}
  canonicalPath="/ja/account-deletion/onul/"
  alternates={accountDeletionAlternates(appId)}
  xDefaultPath="/ko/account-deletion/onul/"
>
  <AccountDeletion lang="ja" appName={appName} />
</Layout>
