---
import { apps } from '../i18n/apps';
import type { UngyeolServiceInfo } from '../i18n/ungyeolServices';

interface Props {
  service: UngyeolServiceInfo;
}

const { service } = Astro.props;
const ungyeol = apps.find((app) => app.id === 'ungyeol');
const appUrl = ungyeol?.googlePlayUrl ?? 'https://play.google.com/store/apps/details?id=com.kokomasoft.ungyeol';
---

<section class="service-hero">
  <div class="container service-hero-layout">
    <div class="service-hero-copy">
      <a class="back-link" href="/ko/#ungyeol-tools">운결 미니서비스</a>
      <p class="eyebrow">{service.eyebrow}</p>
      <h1>{service.title}</h1>
      <p>{service.lead}</p>
    </div>
    <aside class="service-note">
      <h2>무료 웹 미니 풀이</h2>
      <p>입력 내용은 브라우저 안에서만 처리됩니다. 정밀 AI 풀이, 히스토리 저장, 사진 기반 관상은 운결 앱에서 이용할 수 있습니다.</p>
    </aside>
  </div>
</section>

<section class="tool-section">
  <div class="container tool-layout">
    <form class="tool-form" data-service-form>
      <div class="form-head">
        <h2>{service.navLabel}</h2>
        <p>{service.description}</p>
      </div>

      {service.fields.map((field) => (
        <label class:list={['field', { wide: field.type === 'textarea' }]}>
          <span>{field.label}</span>
          {field.type === 'select' ? (
            <select name={field.name} required={field.required}>
              {field.options?.map((option) => <option value={option}>{option}</option>)}
            </select>
          ) : field.type === 'textarea' ? (
            <textarea
              name={field.name}
              required={field.required}
              placeholder={field.placeholder}
              rows="5"
            ></textarea>
          ) : (
            <input
              name={field.name}
              type={field.type}
              required={field.required}
              placeholder={field.placeholder}
            />
          )}
        </label>
      ))}

      <button class="submit-button" type="submit">미니 풀이 보기</button>
      <p class="form-disclaimer">엔터테인먼트 목적의 참고용 결과입니다. 중요한 결정은 현실의 정보와 본인의 판단을 함께 고려해 주세요.</p>
    </form>

    <div class="result-panel" data-result-panel aria-live="polite">
      <div class="empty-result">
        <p class="eyebrow">{service.resultTitle}</p>
        <h2>입력 후 결과가 여기에 표시됩니다</h2>
        <p>짧은 풀이를 확인한 뒤, 앱에서 더 자세한 해석으로 이어갈 수 있습니다.</p>
      </div>
    </div>
  </div>
</section>

<section class="app-cta">
  <div class="container app-cta-layout">
    <div>
      <p class="eyebrow">Ungyeol App</p>
      <h2>더 자세한 풀이는 앱에서 이어보세요</h2>
      <p>{service.appPitch}</p>
    </div>
    <a class="app-button" href={appUrl} target="_blank" rel="noopener noreferrer">Google Play에서 열기</a>
  </div>
</section>

<script type="application/json" data-service-config set:html={JSON.stringify(service)}></script>

<script>
  const configElement = document.querySelector('[data-service-config]');
  const form = document.querySelector('[data-service-form]');
  const resultPanel = document.querySelector('[data-result-panel]');
  const service = JSON.parse(configElement?.textContent || '{}');

  const cards = [
    ['바보', '새로운 시작과 가벼운 용기'],
    ['마법사', '상황을 바꿀 수 있는 주도권'],
    ['여사제', '겉보다 속을 읽어야 하는 흐름'],
    ['여제', '관계와 감정의 회복력'],
    ['황제', '기준을 세우고 질서를 잡는 힘'],
    ['교황', '조언과 원칙이 필요한 시기'],
    ['연인', '끌림과 선택의 갈림길'],
    ['전차', '밀고 나가도 되는 추진력'],
    ['힘', '부드럽게 버티는 인내'],
    ['은둔자', '혼자 정리해야 보이는 답'],
    ['운명의 수레바퀴', '흐름이 바뀌는 전환점'],
    ['정의', '균형과 책임을 맞춰야 하는 순간'],
    ['매달린 사람', '속도를 늦추면 보이는 관점'],
    ['죽음', '끝내야 새로 시작되는 변화'],
    ['절제', '과하지 않게 섞어내는 조율'],
    ['별', '작은 희망이 살아나는 징조'],
    ['달', '불안과 착각을 구분해야 하는 밤'],
    ['태양', '분명해지고 밝아지는 흐름'],
    ['심판', '미뤄둔 결정을 다시 보는 때'],
    ['세계', '한 단락을 마무리하는 완성감'],
  ];

  const moods = ['차분함', '기대감', '조심스러움', '회복', '정리', '전환'];
  const advice = [
    '오늘은 결론을 서두르기보다 작은 확인부터 하는 편이 좋습니다.',
    '상대나 상황을 단정하기 전에 한 번 더 맥락을 살피면 실수가 줄어듭니다.',
    '말을 줄이고 행동을 분명히 하면 흐름이 더 안정됩니다.',
    '기분에 끌려가기보다 오늘 할 수 있는 가장 작은 선택에 집중해 보세요.',
    '관계에서는 강한 표현보다 여지를 남기는 말이 더 잘 통합니다.',
    '미뤄둔 정리를 하나 끝내면 다음 흐름이 가벼워집니다.',
  ];
  const strengths = ['관찰력', '회복력', '표현력', '직감', '균형감', '추진력'];
  const cautions = ['과한 해석', '성급한 답장', '감정 소모', '미룬 결정', '기대치 과잉', '혼자 결론내리기'];

  function hash(value) {
    return Array.from(value).reduce((acc, char) => {
      return (acc * 31 + char.charCodeAt(0)) >>> 0;
    }, 2166136261);
  }

  function pick(list, seed, offset = 0) {
    return list[(seed + offset) % list.length];
  }

  function collectValues(currentForm) {
    const data = new FormData(currentForm);
    return Object.fromEntries([...data.entries()].map(([key, value]) => [key, String(value).trim()]));
  }

  function sentenceFromText(text) {
    if (!text) return '입력한 상황';
    const compact = text.replace(/\s+/g, ' ').trim();
    return compact.length > 72 ? `${compact.slice(0, 72)}...` : compact;
  }

  function buildReply(values, seed) {
    const tone = values.tone || '부드러운 존댓말';
    const goal = values.goal || '대화 이어가기';
    const polite = tone.includes('존댓말');
    const ending = polite ? '요' : '';
    const base = {
      '관심 표현': [
        `나도 그 얘기 조금 더 듣고 싶${polite ? '어요' : '어'}. 편할 때 이어서 말해줄래${ending}?`,
        `그 말 들으니까 괜히 신경 쓰이네${polite ? '요' : ''}. 오늘은 어땠${polite ? '어요' : '어'}?`,
        `나도 너랑 이야기하는 게 편하${polite ? '네요' : '네'}. 조금 더 얘기해보자${polite ? '요' : ''}.`,
      ],
      '약속 잡기': [
        `그럼 말 나온 김에 이번 주에 잠깐 볼까요? 부담 없는 시간으로 맞춰봐${polite ? '요' : ''}.`,
        `괜찮으면 커피라도 한잔하면서 얘기해${polite ? '요' : '자'}. 가능한 날 있어${ending}?`,
        `메시지로만 말하기 아쉬워서, 시간 맞으면 직접 얘기하고 싶${polite ? '어요' : '어'}.`,
      ],
      '사과하기': [
        `내가 그 부분은 더 배려했어야 했${polite ? '어요' : '어'}. 불편했다면 미안해${polite ? '요' : ''}.`,
        `말이 조금 앞섰던 것 같${polite ? '아요' : '아'}. 기분 상했다면 정말 미안해${polite ? '요' : ''}.`,
        `네 입장에서 생각해보니 내가 놓친 게 있더라${polite ? '고요' : ''}. 미안하고, 다시 잘 얘기해보고 싶${polite ? '어요' : '어'}.`,
      ],
      '거리두기': [
        `지금은 서로 조금 차분히 생각할 시간이 필요할 것 같${polite ? '아요' : '아'}. 나중에 다시 얘기해${polite ? '요' : '자'}.`,
        `내가 지금 바로 답을 정하기는 어려워${polite ? '요' : ''}. 조금만 시간을 두고 볼게${polite ? '요' : ''}.`,
        `감정적으로 말하고 싶진 않아서 오늘은 여기까지 할게${polite ? '요' : ''}.`,
      ],
      '대화 이어가기': [
        `그랬구나. 나는 그 부분이 조금 궁금했${polite ? '어요' : '어'}. 너는 어떻게 느꼈${polite ? '어요' : '어'}?`,
        `알겠${polite ? '어요' : '어'}. 그럼 지금은 어떤 쪽이 더 편해${ending}?`,
        `그 얘기 들으니까 상황이 조금 이해돼${polite ? '요' : ''}. 이어서 말해줘${polite ? '요' : ''}.`,
      ],
    };
    return {
      summary: `${values.relationship || '관계'} 관계에서는 ${tone}로 ${goal}의 목적을 분명히 하되, 한 번에 결론을 요구하지 않는 답장이 좋습니다.`,
      sections: [
        { title: '답장 후보 3개', items: base[goal] || base['대화 이어가기'] },
        { title: '주의할 점', text: '상대의 반응이 느리다면 같은 메시지를 반복하기보다 하루 정도 간격을 두는 편이 좋습니다.' },
      ],
    };
  }

  function buildTarot(values, seed) {
    const picked = [0, 1, 2].map((offset) => pick(cards, seed, offset * 7));
    return {
      summary: `${values.topic || '질문'} 흐름은 ${picked[0][0]}에서 시작해 ${picked[2][0]}의 조언으로 정리됩니다.`,
      sections: [
        { title: '현재', text: `${picked[0][0]}: ${picked[0][1]}이 보입니다.` },
        { title: '흐름', text: `${picked[1][0]}: 상황은 ${picked[1][1]} 쪽으로 움직입니다.` },
        { title: '조언', text: `${picked[2][0]}: ${picked[2][1]}을 오늘의 기준으로 삼아보세요.` },
      ],
    };
  }

  function buildResult(values) {
    const seed = hash(`${service.id}:${JSON.stringify(values)}:${new Date().toDateString()}`);
    const mood = pick(moods, seed);
    const strength = pick(strengths, seed, 3);
    const caution = pick(cautions, seed, 5);
    const coreAdvice = pick(advice, seed, 9);

    if (service.id === 'reply') return buildReply(values, seed);
    if (service.id === 'tarot') return buildTarot(values, seed);

    if (service.id === 'dream') {
      return {
        summary: `${values.keyword || '꿈'}은 오늘 마음속 ${mood}과 연결됩니다. ${values.emotion || '감정'}이 강했다면 최근 신경 쓰던 일이 꿈으로 정리되는 흐름입니다.`,
        sections: [
          { title: '상징 해석', text: `${values.keyword || '꿈의 장면'}은 현재 놓치고 있던 감정 신호를 보여줍니다. ${sentenceFromText(values.dreamText)} 장면은 마음이 정리되고 싶어 하는 부분에 가깝습니다.` },
          { title: '오늘의 조언', text: coreAdvice },
          { title: '주의할 점', text: `${caution}에 빠지면 꿈을 과하게 해석할 수 있습니다. 상징은 참고로만 받아들이는 편이 좋습니다.` },
        ],
      };
    }

    if (service.id === 'hidden-feelings') {
      return {
        summary: `${values.relationship || '상대'} 관계는 ${mood}의 기류가 강합니다. 상대는 마음을 완전히 닫았다기보다 속도를 조절하려는 쪽에 가깝습니다.`,
        sections: [
          { title: '상대의 가능성 있는 마음', text: `${sentenceFromText(values.context)} 상황에서는 호감과 부담이 함께 섞여 보입니다. 지금은 확인받으려는 말보다 편한 대화가 더 유리합니다.` },
          { title: '관계 포인트', text: `${values.status || '현재 상황'}에서는 ${strength}을 살리면 분위기가 부드러워집니다.` },
          { title: '다음 행동', text: coreAdvice },
        ],
      };
    }

    if (service.id === 'fortune') {
      return {
        summary: `오늘은 ${mood}이 중심이 되는 날입니다. ${values.focus || '전체'} 흐름에서는 ${strength}을 살리면 기회가 생깁니다.`,
        sections: [
          { title: '전체 흐름', text: '큰 변화보다 작은 정리가 운을 열어주는 날입니다. 미뤄둔 연락, 일정, 결정을 하나만 정리해도 체감이 달라집니다.' },
          { title: '관계/일/금전', text: `${values.focus || '전체'}에서는 ${caution}을 조심하세요. 상대의 반응이나 숫자 하나에 과하게 흔들리지 않는 것이 좋습니다.` },
          { title: '오늘의 조언', text: coreAdvice },
        ],
      };
    }

    if (service.id === 'compatibility') {
      return {
        summary: `${values.relationship || '두 사람'}의 인연은 서로 다른 속도를 맞추는 과정에 있습니다. 끌림은 있지만 표현 방식의 차이를 조율해야 합니다.`,
        sections: [
          { title: '끌림 포인트', text: `두 사람 사이에는 ${strength}이 강점으로 작용합니다. 익숙한 방식보다 상대가 편해하는 표현을 살피면 흐름이 좋아집니다.` },
          { title: '충돌 포인트', text: `${caution}이 반복되면 사소한 말도 크게 느껴질 수 있습니다. 확인 질문을 짧게 던지는 편이 안전합니다.` },
          { title: '오늘의 조언', text: coreAdvice },
        ],
      };
    }

    if (service.id === 'free-question') {
      return {
        summary: `${values.category || '고민'} 질문은 지금 당장 답을 정하기보다 기준을 세우는 단계에 가깝습니다.`,
        sections: [
          { title: '상황 정리', text: `${sentenceFromText(values.question)} 문제는 감정, 현실 조건, 타이밍을 나눠서 보면 더 단순해집니다.` },
          { title: '가능한 방향', text: `${strength}을 살리는 선택은 장기적으로 후회가 적고, ${caution}을 피하는 선택은 오늘의 불안을 줄입니다.` },
          { title: '오늘의 조언', text: coreAdvice },
        ],
      };
    }

    if (service.id === 'face-reading') {
      return {
        summary: `${values.impression || '인상'}은 ${mood}의 분위기를 줍니다. 웹에서는 사진 없이 입력한 키워드만 바탕으로 참고 풀이를 제공합니다.`,
        sections: [
          { title: '인상 흐름', text: `${values.focus || '오늘의 조언'} 기준으로 보면 ${strength}이 강점처럼 보입니다. 첫인상에서는 편안함과 선명함의 균형이 중요합니다.` },
          { title: '활용 팁', text: '중요한 만남 전에는 표정, 시선, 말의 속도를 정돈하는 것만으로도 인상이 크게 달라집니다.' },
          { title: '사진 관상 안내', text: '사진 기반 관상은 앱에서 동의 후 이용할 수 있습니다. 웹에서는 사진을 업로드하거나 저장하지 않습니다.' },
        ],
      };
    }

    return {
      summary: `${service.navLabel} 결과가 준비되었습니다.`,
      sections: [{ title: '오늘의 조언', text: coreAdvice }],
    };
  }

  function renderResult(result) {
    if (!resultPanel) return;
    resultPanel.innerHTML = '';
    const header = document.createElement('div');
    header.className = 'result-head';
    header.innerHTML = `<p class="eyebrow">${service.resultTitle}</p><h2>${result.summary}</h2>`;
    resultPanel.appendChild(header);

    const grid = document.createElement('div');
    grid.className = 'result-grid';
    result.sections.forEach((section) => {
      const item = document.createElement('article');
      item.className = 'result-item';
      const title = document.createElement('h3');
      title.textContent = section.title;
      item.appendChild(title);
      if (section.items) {
        const list = document.createElement('ul');
        section.items.forEach((text) => {
          const li = document.createElement('li');
          li.textContent = text;
          list.appendChild(li);
        });
        item.appendChild(list);
      } else {
        const text = document.createElement('p');
        text.textContent = section.text;
        item.appendChild(text);
      }
      grid.appendChild(item);
    });
    resultPanel.appendChild(grid);
    resultPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const values = collectValues(form);
    renderResult(buildResult(values));
  });
</script>

<style>
  .service-hero {
    padding: 5rem 0 4rem;
    background:
      linear-gradient(120deg, rgba(16, 24, 39, 0.96), rgba(31, 24, 64, 0.9)),
      radial-gradient(circle at 85% 15%, rgba(245, 174, 84, 0.22), transparent 34%);
    color: white;
  }

  .service-hero-layout,
  .tool-layout,
  .app-cta-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 2rem;
    align-items: start;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1.2rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .back-link:hover {
    color: white;
  }

  .eyebrow {
    width: fit-content;
    margin-bottom: 0.85rem;
    padding: 0.32rem 0.72rem;
    border-radius: 999px;
    background: rgba(245, 174, 84, 0.14);
    color: #fbd38d;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .service-hero h1 {
    max-width: 820px;
    margin-bottom: 1rem;
    font-size: clamp(2.7rem, 7vw, 5.6rem);
    font-weight: 850;
    line-height: 0.98;
  }

  .service-hero-copy > p:not(.eyebrow) {
    max-width: 680px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .service-note {
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
  }

  .service-note h2 {
    margin-bottom: 0.55rem;
