  const copy = copyByLang[service.lang] || copyByLang.ko;

  function hash(value) {
    return Array.from(value).reduce((acc, char) => {
      return (acc * 31 + char.charCodeAt(0)) >>> 0;
    }, 2166136261);
  }

  function pick(list, seed, offset = 0) {
    return list[(seed + offset) % list.length];
  }

  function collectValues(currentForm) {
    const data = new FormData(currentForm);
    return Object.fromEntries([...data.entries()].map(([key, value]) => [key, String(value).trim()]));
  }

  function optionIndex(fieldName, value) {
    const field = service.fields?.find((item) => item.name === fieldName);
    const index = field?.options?.indexOf(value);
    return typeof index === 'number' && index >= 0 ? index : 0;
  }

  function sentenceFromText(text) {
    if (!text) return copy.inputFallback;
    const compact = text.replace(/\s+/g, ' ').trim();
    return compact.length > 72 ? `${compact.slice(0, 72)}...` : compact;
  }

  function buildReply(values, seed) {
    const goalIndex = optionIndex('goal', values.goal);
    return {
      summary: copy.reply.summary(values.relationship, values.tone, values.goal),
      sections: [
        { title: copy.reply.title, items: copy.reply.groups[goalIndex] || copy.reply.groups[0] },
        { title: copy.reply.cautionTitle, text: copy.reply.caution },
      ],
    };
  }

  function buildTarot(values, seed) {
    const picked = [0, 1, 2].map((offset) => pick(copy.cards, seed, offset * 7));
    return {
      summary: copy.tarot.summary(values.topic, picked[0][0], picked[2][0]),
      sections: [
        { title: copy.tarot.current, text: copy.tarot.currentText(picked[0]) },
        { title: copy.tarot.flow, text: copy.tarot.flowText(picked[1]) },
        { title: copy.tarot.advice, text: copy.tarot.adviceText(picked[2]) },
      ],
    };
  }

  function buildResult(values) {
    const seed = hash(`${service.id}:${JSON.stringify(values)}:${new Date().toDateString()}`);
    const mood = pick(copy.moods, seed);
    const strength = pick(copy.strengths, seed, 3);
    const caution = pick(copy.cautions, seed, 5);
    const coreAdvice = pick(copy.advice, seed, 9);

    if (service.id === 'reply') return buildReply(values, seed);
    if (service.id === 'tarot') return buildTarot(values, seed);

    if (service.id === 'dream') {
      return {
        summary: copy.dream.summary(values.keyword, values.emotion, mood),
        sections: [
          { title: copy.dream.symbolTitle, text: copy.dream.symbolText(values.keyword, sentenceFromText(values.dreamText)) },
          { title: copy.genericAdviceTitle, text: coreAdvice },
          { title: copy.dream.cautionTitle, text: copy.dream.cautionText(caution) },
        ],
      };
    }

    if (service.id === 'hidden-feelings') {
      return {
        summary: copy.hidden.summary(values.relationship, mood),
        sections: [
          { title: copy.hidden.mindTitle, text: copy.hidden.mindText(sentenceFromText(values.context)) },
          { title: copy.hidden.pointTitle, text: copy.hidden.pointText(values.status, strength) },
          { title: copy.hidden.actionTitle, text: coreAdvice },
        ],
      };
    }

    if (service.id === 'fortune') {
      return {
        summary: copy.fortune.summary(values.focus, mood, strength),
        sections: [
          { title: copy.fortune.overallTitle, text: copy.fortune.overallText },
          { title: copy.fortune.detailTitle, text: copy.fortune.detailText(values.focus, caution) },
          { title: copy.genericAdviceTitle, text: coreAdvice },
        ],
      };
    }

    if (service.id === 'compatibility') {
      return {
        summary: copy.compatibility.summary(values.relationship),
        sections: [
          { title: copy.compatibility.attractionTitle, text: copy.compatibility.attractionText(strength) },
          { title: copy.compatibility.frictionTitle, text: copy.compatibility.frictionText(caution) },
          { title: copy.genericAdviceTitle, text: coreAdvice },
        ],
      };
    }

    if (service.id === 'free-question') {
      return {
        summary: copy.freeQuestion.summary(values.category),
        sections: [
          { title: copy.freeQuestion.situationTitle, text: copy.freeQuestion.situationText(sentenceFromText(values.question)) },
          { title: copy.freeQuestion.directionTitle, text: copy.freeQuestion.directionText(strength, caution) },
          { title: copy.genericAdviceTitle, text: coreAdvice },
        ],
      };
    }

    if (service.id === 'face-reading') {
      return {
        summary: copy.face.summary(values.impression, mood),
        sections: [
          { title: copy.face.flowTitle, text: copy.face.flowText(values.focus, strength) },
          { title: copy.face.tipTitle, text: copy.face.tipText },
          { title: copy.face.photoTitle, text: copy.face.photoText },
        ],
      };
    }

    return {
      summary: copy.resultReady(service.navLabel),
      sections: [{ title: copy.genericAdviceTitle, text: coreAdvice }],
    };
  }

  function renderResult(result) {
    if (!resultPanel) return;
    resultPanel.innerHTML = '';
    const header = document.createElement('div');
    header.className = 'result-head';
    const eyebrow = document.createElement('p');
    eyebrow.className = 'eyebrow';
    eyebrow.textContent = service.resultTitle;
    const title = document.createElement('h2');
    title.textContent = result.summary;
    header.append(eyebrow, title);
    resultPanel.appendChild(header);

    const grid = document.createElement('div');
    grid.className = 'result-grid';
    result.sections.forEach((section) => {
      const item = document.createElement('article');
      item.className = 'result-item';
      const title = document.createElement('h3');
      title.textContent = section.title;
      item.appendChild(title);
      if (section.items) {
        const list = document.createElement('ul');
        section.items.forEach((text) => {
          const li = document.createElement('li');
          li.textContent = text;
          list.appendChild(li);
        });
        item.appendChild(list);
      } else {
        const text = document.createElement('p');
        text.textContent = section.text;
        item.appendChild(text);
      }
      grid.appendChild(item);
    });
    resultPanel.appendChild(grid);
    resultPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const values = collectValues(form);
    renderResult(buildResult(values));
  });
</script>

