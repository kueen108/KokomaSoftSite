---
import { apps } from '../i18n/apps';
import type { UngyeolServiceInfo } from '../i18n/ungyeolServices';

interface Props {
  service: UngyeolServiceInfo;
}

const { service } = Astro.props;
const ungyeol = apps.find((app) => app.id === 'ungyeol');
const appUrl = ungyeol?.googlePlayUrl ?? 'https://play.google.com/store/apps/details?id=com.kokomasoft.ungyeol';
const backHref = `/${service.lang}/#ungyeol-tools`;
---

<section class="service-hero">
  <div class="container service-hero-layout">
    <div class="service-hero-copy">
      <a class="back-link" href={backHref}>{service.ui.backLabel}</a>
      <p class="eyebrow">{service.eyebrow}</p>
      <h1>{service.title}</h1>
      <p>{service.lead}</p>
    </div>
    <aside class="service-note">
      <h2>{service.ui.noteTitle}</h2>
      <p>{service.ui.noteText}</p>
    </aside>
  </div>
</section>

<section class="tool-section">
  <div class="container tool-layout">
    <form class="tool-form" data-service-form>
      <div class="form-head">
        <h2>{service.navLabel}</h2>
        <p>{service.description}</p>
      </div>

      {service.fields.map((field) => (
        <label class:list={['field', { wide: field.type === 'textarea' }]}>
          <span>{field.label}</span>
          {field.type === 'select' ? (
            <select name={field.name} required={field.required}>
              {field.options?.map((option) => <option value={option}>{option}</option>)}
            </select>
          ) : field.type === 'textarea' ? (
            <textarea
              name={field.name}
              required={field.required}
              placeholder={field.placeholder}
              rows="5"
            ></textarea>
          ) : (
            <input
              name={field.name}
              type={field.type}
              required={field.required}
              placeholder={field.placeholder}
            />
          )}
        </label>
      ))}

      <button class="submit-button" type="submit">{service.ui.submitLabel}</button>
      <p class="form-disclaimer">{service.ui.disclaimer}</p>
    </form>

    <div class="result-panel" data-result-panel aria-live="polite">
      <div class="empty-result">
        <p class="eyebrow">{service.resultTitle}</p>
        <h2>{service.ui.emptyTitle}</h2>
        <p>{service.ui.emptyText}</p>
      </div>
    </div>
  </div>
</section>

<section class="app-cta">
  <div class="container app-cta-layout">
    <div>
      <p class="eyebrow">{service.ui.appEyebrow}</p>
      <h2>{service.ui.appTitle}</h2>
      <p>{service.appPitch}</p>
    </div>
    <a class="app-button" href={appUrl} target="_blank" rel="noopener noreferrer">{service.ui.appButtonLabel}</a>
  </div>
</section>

<script type="application/json" data-service-config set:html={JSON.stringify(service)}></script>

