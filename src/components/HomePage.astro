---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { apps } from '../i18n/apps';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const heroScreenshots = apps
  .flatMap((app) =>
    (app.screenshots?.[lang] ?? app.screenshots?.en ?? [])
      .slice(0, 1)
      .map((screenshot) => ({ app, screenshot })),
  )
  .slice(0, 2);
---

<!-- Hero Section -->
<section class="hero">
  <div class="hero-media" aria-hidden="true">
    <div class="hero-screens">
      {heroScreenshots.map(({ screenshot }, index) => (
        <img
          class={`hero-screen hero-screen-${index + 1}`}
          src={screenshot.src}
          alt=""
          loading="eager"
        />
      ))}
    </div>
    <div class="hero-icons">
      {apps.map((app) => (
        <img src={app.iconUrl} alt="" width="52" height="52" />
      ))}
    </div>
  </div>
  <div class="container hero-content">
    <p class="eyebrow">KokomaSoft App Studio</p>
    <h1>{tr.heroTitle}</h1>
    <p>{tr.heroSubtitle}</p>
    <div class="hero-actions">
      <a href={`/${lang}/#apps`} class="hero-btn primary">{tr.appsTitle}</a>
      <a href={`/${lang}/#support`} class="hero-btn secondary">{tr.supportAndPrivacyTitle}</a>
    </div>
  </div>
</section>

<!-- Apps Section -->
<section class="apps" id="apps">
  <div class="container">
    <h2>{tr.appsTitle}</h2>
    <p class="section-subtitle">{tr.appsSubtitle}</p>
    <div class="apps-grid">
      {apps.map((app) => (
        <article class:list={['app-card', { 'has-screenshots': Boolean(app.screenshots) }]}>
          <div class="app-card-head">
            <div class="app-icon">
              <img src={app.iconUrl} alt={`${app.name[lang]} icon`} width="64" height="64" loading="lazy" />
            </div>
            <span class="app-category">{tr.appCategories[app.category]}</span>
          </div>
          <div class="app-info">
            <h3>{app.name[lang]}</h3>
            <p>{app.tagline[lang]}</p>
            <ul class="feature-chips">
              {app.features[lang].slice(0, 3).map((feature) => <li>{feature}</li>)}
            </ul>
            <div class="app-links">
              <a href={`/${lang}/apps/${app.id}/`} class="details-link">
                {tr.learnMore}
              </a>
              {app.googlePlayUrl && (
                <a href={app.googlePlayUrl} target="_blank" rel="noopener noreferrer" class="store-btn google-play">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.545 1.473c.68.394.68 1.047 0 1.44l-2.545 1.474-2.535-2.535 2.535-2.535zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
                  {tr.googlePlay}
                </a>
              )}
              {app.appStoreUrl && (
                <a href={app.appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn app-store">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                  {tr.appStore}
                </a>
              )}
              <a href={`/${lang}/privacy/${app.id}/`} class="privacy-link">
                {tr.privacyPolicy}
              </a>
              {app.supportsAccountDeletion && (
                <a href={`/${lang}/account-deletion/${app.id}/`} class="privacy-link">
                  {tr.accountDeletion}
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Support Section -->
<section class="support" id="support">
  <div class="container">
    <h2>{tr.supportHubTitle}</h2>
    <p class="section-subtitle">{tr.supportHubSubtitle}</p>
    <div class="support-grid">
      {tr.supportHighlights.map((item) => (
        <article class="support-item">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- About Section -->
<section class="about" id="about">
  <div class="container">
    <h2>{tr.aboutTitle}</h2>
    <p>{tr.aboutDescription}</p>
  </div>
</section>

<!-- Contact Section -->
<section class="contact" id="contact">
  <div class="container">
    <h2>{tr.contactTitle}</h2>
    <p>{tr.contactEmail}: <a href="mailto:kokomasoft@gmail.com">kokomasoft@gmail.com</a></p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(760px, calc(100svh - 64px));
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #101827;
    color: white;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(16, 24, 39, 0.96) 0%, rgba(16, 24, 39, 0.78) 46%, rgba(16, 24, 39, 0.36) 100%),
      linear-gradient(180deg, rgba(245, 174, 84, 0.22), rgba(38, 166, 154, 0.16));
    z-index: 1;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 26%;
    background: linear-gradient(180deg, rgba(16, 24, 39, 0), var(--color-bg));
    z-index: 2;
    pointer-events: none;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-screens {
    position: absolute;
    top: 8%;
    right: max(2rem, calc((100vw - var(--max-width)) / 2));
    width: min(42vw, 520px);
    height: 78%;
  }

  .hero-screen {
    position: absolute;
    width: min(240px, 42vw);
    aspect-ratio: 9 / 16;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 8px;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.4);
  }

  .hero-screen-1 {
    right: 34%;
    top: 9%;
    transform: rotate(-7deg);
  }

  .hero-screen-2 {
    right: 0;
    top: 21%;
    transform: rotate(6deg);
  }

  .hero-icons {
    position: absolute;
    right: max(1.5rem, calc((100vw - var(--max-width)) / 2));
    bottom: 17%;
    display: flex;
    gap: 0.7rem;
    padding: 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(18px);
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.22);
  }

  .hero-icons img {
    width: 52px;
    height: 52px;
    border-radius: 8px;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    padding-top: 5rem;
    padding-bottom: 7rem;
  }

  .eyebrow {
    width: fit-content;
    margin-bottom: 1.2rem;
    padding: 0.34rem 0.74rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    color: #c7f9ea;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 780px;
    margin-bottom: 1.15rem;
    color: white;
    font-size: clamp(3rem, 9vw, 6.8rem);
    font-weight: 800;
    line-height: 0.94;
  }

  .hero-content > p:not(.eyebrow) {
    max-width: 610px;
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0.68rem 1.05rem;
    border-radius: 8px;
    font-size: 0.92rem;
    font-weight: 800;
    text-decoration: none;
  }

  .hero-btn.primary {
    background: #f5ae54;
    color: #111827;
  }

  .hero-btn.secondary {
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
    background: rgba(255, 255, 255, 0.09);
    backdrop-filter: blur(14px);
  }

  section h2 {
    font-size: clamp(2.1rem, 4vw, 3.6rem);
    font-weight: 800;
    line-height: 1;
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin: 0 auto 2.75rem;
    max-width: 660px;
    font-size: 1.02rem;
  }

  .apps {
    padding: 6rem 0;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
  }

  .app-card {
    grid-column: span 6;
    min-height: 360px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.35rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.9) inset;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .app-card:nth-child(1) {
    background: linear-gradient(135deg, #fff8e8 0%, #ffffff 52%, #e8f7f2 100%);
  }

  .app-card:nth-child(2) {
    background: linear-gradient(135deg, #fff0eb 0%, #ffffff 54%, #eef4ff 100%);
  }

  .app-card:nth-child(3) {
    grid-column: span 7;
    background: linear-gradient(135deg, #e9fbf4 0%, #ffffff 56%, #f3f1ff 100%);
  }

  .app-card:nth-child(4) {
    grid-column: span 5;
    background: linear-gradient(135deg, #f4efff 0%, #ffffff 54%, #fff5dc 100%);
  }

  .app-card:hover {
    border-color: rgba(15, 118, 110, 0.42);
    box-shadow: var(--shadow-soft);
    transform: translateY(-5px);
  }

  .app-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .app-icon {
    width: 70px;
    height: 70px;
    border-radius: 8px;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--color-bg-alt);
    box-shadow: 0 14px 38px rgba(15, 23, 42, 0.16);
  }

  .app-icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .app-info {
    flex: 1;
  }

  .app-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--color-primary);
    background: rgba(15, 118, 110, 0.1);
    padding: 0.28rem 0.62rem;
    border-radius: 999px;
    text-transform: uppercase;
  }

  .app-info h3 {
    font-size: clamp(1.55rem, 2.6vw, 2.25rem);
    font-weight: 800;
    line-height: 1.08;
    margin-bottom: 0.7rem;
  }

  .app-info p {
    font-size: 0.98rem;
    color: var(--color-text-muted);
    margin-bottom: 1.2rem;
    line-height: 1.68;
  }

  .feature-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.35rem;
    list-style: none;
  }

  .feature-chips li {
    padding: 0.4rem 0.6rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    color: var(--color-ink-soft);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .app-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }

  .details-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .details-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .store-btn.google-play {
    background: var(--color-ink);
    color: white;
  }

  .store-btn.google-play:hover {
    background: #334155;
  }

  .privacy-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.5rem 0;
  }

  .privacy-link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .store-btn.app-store {
    background: var(--color-primary);
    color: white;
  }

  .store-btn.app-store:hover {
    background: var(--color-primary-dark);
  }

  .support {
    padding: 5rem 0;
    background: #101827;
    color: white;
  }

  .support .section-subtitle {
    color: rgba(255, 255, 255, 0.68);
  }

  .support-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .support-item {
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(14px);
  }

  .support-item h3 {
    font-size: 1rem;
    margin-bottom: 0.55rem;
  }

  .support-item p {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .about {
    padding: 5rem 0;
    background: var(--color-bg);
  }

  .about p {
    max-width: 700px;
    margin: 1rem auto 0;
    text-align: center;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .contact {
    padding: 5rem 0;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, #edf2ed 100%);
  }

  .contact p {
    color: var(--color-text-muted);
    margin-top: 1rem;
  }

  .contact a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .contact a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 720px;
      align-items: flex-start;
    }

    .hero::before {
      background:
        linear-gradient(180deg, rgba(16, 24, 39, 0.96) 0%, rgba(16, 24, 39, 0.86) 54%, rgba(16, 24, 39, 0.52) 100%),
        linear-gradient(180deg, rgba(245, 174, 84, 0.2), rgba(38, 166, 154, 0.14));
    }

    .hero-content {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .hero-screens {
      top: auto;
      right: 0;
      bottom: 2.5rem;
      width: 100%;
      height: 270px;
    }

    .hero-screen {
      width: 150px;
    }

    .hero-screen-1 {
      right: 44%;
      top: 0;
    }

    .hero-screen-2 {
      right: 9%;
      top: 38px;
    }

    .hero-icons {
      right: auto;
      left: 1.5rem;
      bottom: 2rem;
      gap: 0.45rem;
    }

    .hero-icons img {
      width: 42px;
      height: 42px;
    }

    .apps {
      padding: 4.5rem 0;
    }

    .apps-grid,
    .support-grid {
      grid-template-columns: 1fr;
    }

    .app-card,
    .app-card:nth-child(3),
    .app-card:nth-child(4) {
      grid-column: auto;
    }

    .app-card {
      min-height: 0;
    }

    .app-links {
      align-items: flex-start;
    }
  }
</style>
