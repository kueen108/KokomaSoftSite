---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { apps } from '../i18n/apps';
import { getUngyeolLandingCopy, getUngyeolServices } from '../i18n/ungyeolServices';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const ungyeolServices = getUngyeolServices(lang);
const ungyeolTools = getUngyeolLandingCopy(lang);

type AppEntry = (typeof apps)[number];

const localizedShots = (app: AppEntry) =>
  app.screenshots?.[lang] ?? app.screenshots?.en ?? app.screenshots?.ko ?? [];

// Marquee strip: 10 hand-picked 9:16 screenshots (lifepension excluded — different ratio)
const marqueePicks: Record<string, number> = {
  ungyeol: 2,
  checkme: 2,
  smartbap: 2,
  marknote: 2,
  onul: 2,
};
const marqueeShots = apps.flatMap((app) => {
  const count = marqueePicks[app.id] ?? 0;
  return localizedShots(app)
    .slice(0, count)
    .map((shot) => ({ appId: app.id, src: shot.src }));
});
const marqueeRowA = marqueeShots.filter((_, i) => i % 2 === 0);
const marqueeRowB = marqueeShots.filter((_, i) => i % 2 === 1);

// Bento grid: explicit render order so auto-placement fills without holes
// 6-col math: hero(4x2) + 2 sm fill rows 1-2, 3 sm fill row 3, 2 md fill row 4
const bentoOrder = ['ungyeol', 'smartbap', 'checkme', 'onul', 'marknote', 'mytube', 'lifelotto', 'lifepension'];
const bentoApps = bentoOrder
  .map((id) => apps.find((app) => app.id === id))
  .filter((app): app is AppEntry => Boolean(app));
const tileClass = (id: string) =>
  id === 'ungyeol'
    ? 'tile-hero'
    : id === 'lifelotto' || id === 'lifepension'
      ? 'tile-md'
      : 'tile-sm';
// Hero tile gets more chips to fill its height; sm tiles get fewer to keep rows short
const chipCount = (id: string) => {
  const cls = tileClass(id);
  return cls === 'tile-hero' ? 5 : cls === 'tile-sm' ? 2 : 3;
};
const ungyeolShot = localizedShots(apps.find((app) => app.id === 'ungyeol')!)[0];
const floatingIcons = apps.map((app) => app.iconUrl);
---

<!-- Hero -->
<section class="hero">
  <div class="hero-aurora" aria-hidden="true">
    <span class="blob blob-1"></span>
    <span class="blob blob-2"></span>
    <span class="blob blob-3"></span>
  </div>
  <div class="hero-icons" aria-hidden="true">
    {floatingIcons.map((src) => (
      <img src={src} alt="" width="56" height="56" loading="lazy" decoding="async" />
    ))}
  </div>
  <div class="container hero-content">
    <p class="eyebrow">KokomaSoft App Studio</p>
    <h1>{tr.heroTitle}</h1>
    <p class="hero-subtitle">{tr.heroSubtitle}</p>
    <div class="hero-actions">
      <a href={`/${lang}/#apps`} class="hero-btn primary">{tr.appsTitle}</a>
      <a href={`/${lang}/#support`} class="hero-btn secondary">{tr.supportAndPrivacyTitle}</a>
      <a href="https://blog.kokomasoft.com/?entry=kokomasoft-main" class="hero-btn secondary">{tr.blogCta}</a>
    </div>
  </div>
</section>

<!-- Marquee strip (decorative) -->
<section class="marquee-band" aria-hidden="true">
  <div class="marquee">
    <div class="marquee-track">
      <div class="marquee-group">
        {marqueeRowA.map(({ src }, i) => (
          <figure class="phone">
            <img
              src={src}
              alt=""
              width="540"
              height="960"
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </figure>
        ))}
      </div>
      <div class="marquee-group" aria-hidden="true">
        {marqueeRowA.map(({ src }) => (
          <figure class="phone">
            <img src={src} alt="" width="540" height="960" loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </div>
  </div>
  <div class="marquee reverse">
    <div class="marquee-track">
      <div class="marquee-group">
        {marqueeRowB.map(({ src }) => (
          <figure class="phone">
            <img src={src} alt="" width="540" height="960" loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
      <div class="marquee-group" aria-hidden="true">
        {marqueeRowB.map(({ src }) => (
          <figure class="phone">
            <img src={src} alt="" width="540" height="960" loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Apps bento grid -->
<section class="apps" id="apps">
  <div class="container">
    <div class="section-head" data-reveal>
      <h2>{tr.appsTitle}</h2>
      <p class="section-subtitle">{tr.appsSubtitle}</p>
    </div>
    <div class="bento">
      {bentoApps.map((app, index) => (
        <article class:list={['tile', tileClass(app.id)]} data-reveal style={`--reveal-i:${index}`}>
          <div class="tile-body">
            <div class="tile-head">
              <img
                class="tile-icon"
                src={app.iconUrl}
                alt={`${app.name[lang]} icon`}
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              />
              <span class="tile-category">{tr.appCategories[app.category]}</span>
            </div>
            <h3>{app.name[lang]}</h3>
            <p class="tile-tagline">{app.tagline[lang]}</p>
            <ul class="feature-chips">
              {app.features[lang].slice(0, chipCount(app.id)).map((feature) => <li>{feature}</li>)}
            </ul>
            <div class="app-links">
              <a href={`/${lang}/apps/${app.id}/`} class="details-link">
                {tr.learnMore}
              </a>
              {lang === 'ko' && app.introVideoUrl && (
                <a href={app.introVideoUrl} target="_blank" rel="noopener noreferrer" class="store-btn video-link">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                  {tr.appIntroVideo}
                </a>
              )}
              {app.webUrl && (
                <a href={app.webUrl} target="_blank" rel="noopener noreferrer" class="store-btn web-app">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm6.93 6h-2.95a15.7 15.7 0 00-1.38-3.56A8.03 8.03 0 0118.93 8zM12 4c.83 1.2 1.48 2.53 1.91 4h-3.82c.43-1.47 1.08-2.8 1.91-4zM4.26 14a7.96 7.96 0 010-4h3.38a16.6 16.6 0 000 4H4.26zm.81 2h2.95c.32 1.25.78 2.45 1.38 3.56A8.03 8.03 0 015.07 16zm2.95-8H5.07a8.03 8.03 0 014.33-3.56A15.7 15.7 0 008.02 8zM12 20c-.83-1.2-1.48-2.53-1.91-4h3.82A13.9 13.9 0 0112 20zm2.34-6H9.66a14.7 14.7 0 010-4h4.68a14.7 14.7 0 010 4zm.27 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 01-4.33 3.56zM16.36 14a16.6 16.6 0 000-4h3.38a7.96 7.96 0 010 4h-3.38z"/></svg>
                  {tr.openWebApp}
                </a>
              )}
              {app.googlePlayUrl && (
                <a href={app.googlePlayUrl} target="_blank" rel="noopener noreferrer" class="store-btn google-play">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.545 1.473c.68.394.68 1.047 0 1.44l-2.545 1.474-2.535-2.535 2.535-2.535zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
                  {tr.googlePlay}
                </a>
              )}
              {app.appStoreUrl && (
                <a href={app.appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn app-store">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                  {tr.appStore}
                </a>
              )}
              <a href={`/${lang}/privacy/${app.id}/`} class="privacy-link">
                {tr.privacyPolicy}
              </a>
              {app.supportsAccountDeletion && (
                <a href={`/${lang}/account-deletion/${app.id}/`} class="privacy-link">
                  {tr.accountDeletion}
                </a>
              )}
            </div>
          </div>
          {app.id === 'ungyeol' && ungyeolShot && (
            <figure class="tile-shot phone" aria-hidden="true">
              <img src={ungyeolShot.src} alt="" width="540" height="960" loading="lazy" decoding="async" />
            </figure>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Blog -->
<section class="blog-entry" id="blog">
  <div class="container">
    <div class="blog-entry-card" data-reveal>
      <div class="blog-entry-copy">
        <p class="card-eyebrow">KokomaSoft Blog</p>
        <h2>{tr.blogTitle}</h2>
        <p class="section-subtitle">{tr.blogSubtitle}</p>
        <ul class="blog-theme-list" aria-label={tr.blogTitle}>
          {tr.blogThemes.map((theme) => (
            <li>
              <span>{theme.label}</span>
              <p>{theme.description}</p>
            </li>
          ))}
        </ul>
      </div>
      <a href="https://blog.kokomasoft.com/?entry=kokomasoft-main" class="blog-link">{tr.blogCta}</a>
    </div>
  </div>
</section>

<!-- Ungyeol web tools -->
<section class="ungyeol-tools" id="ungyeol-tools">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="card-eyebrow">{ungyeolTools.eyebrow}</p>
      <h2>{ungyeolTools.title}</h2>
      <p class="section-subtitle">{ungyeolTools.subtitle}</p>
    </div>
    <div class="tools-grid">
      {ungyeolServices.map((service, index) => (
        <a class="tool-card" href={service.path} data-reveal style={`--reveal-i:${index}`}>
          <span class="tool-tag">{service.eyebrow}</span>
          <h3>{service.navLabel}</h3>
          <p>{service.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Support -->
<section class="support" id="support">
  <div class="container">
    <div class="section-head" data-reveal>
      <h2>{tr.supportHubTitle}</h2>
      <p class="section-subtitle">{tr.supportHubSubtitle}</p>
    </div>
    <div class="support-grid">
      {tr.supportHighlights.map((item, index) => (
        <article class="support-item" data-reveal style={`--reveal-i:${index}`}>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- About -->
<section class="about" id="about">
  <div class="container" data-reveal>
    <h2>{tr.aboutTitle}</h2>
    <p>{tr.aboutDescription}</p>
  </div>
</section>

<!-- Contact -->
<section class="contact" id="contact">
  <div class="container" data-reveal>
    <h2>{tr.contactTitle}</h2>
    <p>
      {tr.contactEmail}:
      <a class="contact-pill" href="mailto:kokomasoft@gmail.com">kokomasoft@gmail.com</a>
    </p>
  </div>
</section>

<style>
  section[id] {
    scroll-margin-top: 80px;
  }

  :global(html[lang='ko']) h1,
  :global(html[lang='ko']) h2,
  :global(html[lang='ko']) h3 {
    word-break: keep-all;
  }

  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    min-height: calc(100svh - 64px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--ink-deep);
    color: #f1f0fa;
  }

  /* Faint grid texture */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 40%, #000 30%, transparent 75%);
    z-index: 0;
    pointer-events: none;
  }

  .hero-aurora {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.3;
    will-change: transform;
  }

  .blob-1 {
    width: 46vw;
    height: 46vw;
    min-width: 380px;
    min-height: 380px;
    background: var(--neon-purple);
    top: -12%;
    left: -8%;
    animation: drift-a 19s ease-in-out infinite alternate;
  }

  .blob-2 {
    width: 38vw;
    height: 38vw;
    min-width: 320px;
    min-height: 320px;
    background: var(--neon-pink);
    top: 18%;
    right: -10%;
    animation: drift-b 23s ease-in-out infinite alternate;
  }

  .blob-3 {
    width: 34vw;
    height: 34vw;
    min-width: 300px;
    min-height: 300px;
    background: var(--neon-cyan);
    bottom: -18%;
    left: 32%;
    opacity: 0.22;
    animation: drift-a 27s ease-in-out infinite alternate-reverse;
  }

  @keyframes drift-a {
    to {
      transform: translate3d(8vw, 6vh, 0) scale(1.12);
    }
  }

  @keyframes drift-b {
    to {
      transform: translate3d(-7vw, -5vh, 0) scale(0.92);
    }
  }

  .hero-icons {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero-icons img {
    position: absolute;
    width: 56px;
    height: 56px;
    border-radius: 16px;
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.5), 0 0 24px rgba(139, 92, 246, 0.25);
    opacity: 0.92;
    animation: float 7s ease-in-out infinite;
  }

  .hero-icons img:nth-child(1) { top: 16%; right: 12%; animation-delay: 0s; }
  .hero-icons img:nth-child(2) { top: 38%; right: 5%; width: 44px; height: 44px; animation-delay: -1.6s; }
  .hero-icons img:nth-child(3) { top: 62%; right: 16%; animation-delay: -3.1s; }
  .hero-icons img:nth-child(4) { top: 12%; right: 28%; width: 40px; height: 40px; animation-delay: -4.4s; }
  .hero-icons img:nth-child(5) { top: 74%; right: 32%; width: 48px; height: 48px; animation-delay: -2.2s; }
  .hero-icons img:nth-child(6) { top: 44%; right: 24%; width: 64px; height: 64px; animation-delay: -5.5s; }
  .hero-icons img:nth-child(7) { top: 26%; right: 40%; width: 38px; height: 38px; animation-delay: -6.3s; }
  .hero-icons img:nth-child(8) { top: 58%; right: 42%; width: 46px; height: 46px; animation-delay: -3.8s; }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(-2deg);
    }
    50% {
      transform: translateY(-16px) rotate(3deg);
    }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 7rem 0 6rem;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c4f6ff;
    margin-bottom: 1.6rem;
  }

  .hero h1 {
    max-width: 14ch;
    font-size: clamp(3.2rem, 10vw, 8rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin-bottom: 1.4rem;
  }

  @supports (background-clip: text) or (-webkit-background-clip: text) {
    .hero h1 {
      background: linear-gradient(110deg, #c4b5fd 0%, #8b5cf6 22%, #ec4899 52%, #22d3ee 88%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
  }

  .hero-subtitle {
    max-width: 36rem;
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: #b9b6d4;
    margin-bottom: 2.4rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 1.7rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.35s var(--ease-spring), box-shadow 0.35s var(--ease-spring);
  }

  .hero-btn.primary {
    background: var(--gradient-neon);
    color: #0a0a14;
    box-shadow: 0 0 24px rgba(139, 92, 246, 0.45), 0 0 48px rgba(236, 72, 153, 0.22);
  }

  .hero-btn.primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 32px rgba(139, 92, 246, 0.65), 0 0 64px rgba(236, 72, 153, 0.35);
  }

  .hero-btn.secondary {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: #f1f0fa;
    backdrop-filter: blur(8px);
  }

  .hero-btn.secondary:hover {
    transform: translateY(-3px);
    border-color: rgba(34, 211, 238, 0.5);
    box-shadow: 0 0 24px rgba(34, 211, 238, 0.2);
  }

  /* ---------- Marquee ---------- */
  .marquee-band {
    display: grid;
    gap: 1.2rem;
    padding: 1.5rem 0 3rem;
    overflow: hidden;
  }

  .marquee {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 48s linear infinite;
    will-change: transform;
  }

  .marquee.reverse .marquee-track {
    animation-direction: reverse;
  }

  .marquee-group {
    display: flex;
    gap: 1.2rem;
    padding-right: 1.2rem;
  }

  @keyframes marquee-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  .phone {
    flex-shrink: 0;
    width: 200px;
    padding: 6px;
    border-radius: 1.7rem;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.04));
    border: 1px solid var(--glass-border);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
    margin: 0;
  }

  .phone img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    border-radius: 1.35rem;
  }

  /* ---------- Shared section bits ---------- */
  .section-head {
    margin-bottom: 2.6rem;
  }

  .section-head h2,
  .blog-entry-card h2,
  .about h2,
  .contact h2 {
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin-bottom: 0.7rem;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    max-width: 42rem;
    font-size: 1.02rem;
  }

  .card-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--gradient-neon);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.7rem;
  }

  /* ---------- Bento apps ---------- */
  .apps {
    padding: 4.5rem 0 5.5rem;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.1rem;
  }

  .tile {
    position: relative;
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: 1.6rem;
    overflow: hidden;
    transition: transform 0.45s var(--ease-spring);
  }

  .tile::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: var(--gradient-neon);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .tile:hover {
    transform: perspective(900px) rotateX(1.6deg) rotateY(-1.6deg) translateY(-5px);
  }

  .tile:hover::before {
    opacity: 0.9;
  }

  .tile-hero {
    grid-column: span 4;
    grid-row: span 2;
    background: var(--glass-bg);
    backdrop-filter: blur(14px);
  }

  .tile-sm {
    grid-column: span 2;
  }

  .tile-md {
    grid-column: span 3;
  }

  .tile-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tile-hero .tile-body {
    max-width: 60%;
  }

  .tile-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1rem;
