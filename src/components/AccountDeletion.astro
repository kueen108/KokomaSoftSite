---
import type { Lang } from '../i18n/translations';
import { accountDeletion, supportEmail } from '../i18n/accountDeletion';

interface Props {
  lang: Lang;
  appName: string;
}

const { lang, appName } = Astro.props;
const copy = accountDeletion[lang];
const mailSubject = encodeURIComponent(copy.emailSubject(appName));
---

<section class="account-deletion">
  <div class="container">
    <a href={`/${lang}/`} class="back-link">KokomaSoft</a>
    <h1>{copy.title}</h1>
    <p class="app-name">{appName}</p>
    <p class="last-updated">{copy.lastUpdated}</p>
    <p class="subtitle">{copy.subtitle(appName)}</p>

    <div class="panel primary-panel">
      <h2>{copy.requestHeading}</h2>
      <p>{copy.requestIntro}</p>
      <a
        class="email-button"
        href={`mailto:${supportEmail}?subject=${mailSubject}`}
      >
        {copy.emailCta}
      </a>
      <p class="email-address">{supportEmail}</p>
    </div>

    <div class="section">
      <h2>{copy.overviewHeading}</h2>
      <p>{copy.overview(appName)}</p>
    </div>

    <div class="section">
      <h2>{copy.includeHeading}</h2>
      <ul>
        {copy.includeItems.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="section">
      <h2>{copy.deletionHeading}</h2>
      <ul>
        {copy.deletionItems.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="section">
      <h2>{copy.retentionHeading}</h2>
      <p>{copy.retention}</p>
    </div>

    <div class="section">
      <h2>{copy.subscriptionHeading}</h2>
      <p>{copy.subscription}</p>
    </div>

    <div class="section">
      <h2>{copy.timelineHeading}</h2>
      <p>{copy.timeline}</p>
    </div>
  </div>
</section>

<style>
  .account-deletion {
    padding: 4rem 0;
  }

  .account-deletion .container {
    max-width: 820px;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0.25rem;
  }

  .app-name {
    font-size: 1.1rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .last-updated {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .subtitle {
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .panel {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    background: var(--color-bg-alt);
  }

  .primary-panel {
    border-color: #bfdbfe;
    background: #eff6ff;
  }

  .section {
    margin-bottom: 1.75rem;
  }

  h2 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.65rem;
  }

  p,
  li {
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  ul {
    padding-left: 1.25rem;
  }

  li + li {
    margin-top: 0.35rem;
  }

  .email-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
    padding: 0.75rem 1.1rem;
    border-radius: 8px;
    background: var(--color-primary);
    color: white;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .email-button:hover {
    background: var(--color-primary-dark);
  }

  .email-address {
    margin-top: 0.75rem;
    color: var(--color-text);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .account-deletion {
      padding: 3rem 0;
    }

    h1 {
      font-size: 1.7rem;
    }

    .panel {
      padding: 1.25rem;
    }
  }
</style>
