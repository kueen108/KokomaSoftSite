---
import type { Lang } from '../i18n/translations';
import { privacy } from '../i18n/privacy';

interface Props {
  lang: Lang;
  appName: string;
}

const { lang, appName } = Astro.props;
const p = privacy[lang];
---

<section class="privacy">
  <div class="container">
    <h1>{p.title}</h1>
    <p class="app-name">{appName}</p>
    <p class="last-updated">{p.lastUpdated}</p>
    <p class="intro">{p.intro(appName)}</p>
    {p.sections.map((section) => (
      <div class="section">
        <h2>{section.heading}</h2>
        <p>{section.content}</p>
      </div>
    ))}
    <div class="section">
      <p>{p.contact}</p>
      <p><a href="mailto:kokomasoft@gmail.com">kokomasoft@gmail.com</a></p>
    </div>
  </div>
</section>

<style>
  .privacy {
    padding: 4rem 0;
  }

  .privacy .container {
    max-width: 800px;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .app-name {
    font-size: 1.1rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .last-updated {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .intro {
    line-height: 1.8;
    margin-bottom: 2rem;
    color: var(--color-text);
  }

  .section {
    margin-bottom: 1.5rem;
  }

  .section h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-align: left;
  }

  .section p {
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .section a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .section a:hover {
    text-decoration: underline;
  }
</style>
