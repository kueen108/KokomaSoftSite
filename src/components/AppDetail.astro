---
import type { AppInfo } from '../i18n/apps';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { ungyeolServices } from '../i18n/ungyeolServices';

interface Props {
  app: AppInfo;
  lang: Lang;
}

const { app, lang } = Astro.props;
const tr = t(lang);
const screenshots = app.screenshots?.[lang] ?? app.screenshots?.en ?? [];
---

<section class="app-hero">
  <div class="detail-backdrop" aria-hidden="true">
    {screenshots.slice(0, 2).map((screenshot, index) => (
      <img class={`backdrop-shot backdrop-shot-${index + 1}`} src={screenshot.src} alt="" />
    ))}
  </div>
  <div class="container">
    <a class="back-link" href={`/${lang}/#apps`}>{tr.backToApps}</a>
    <div class="app-heading">
      <img src={app.iconUrl} alt={`${app.name[lang]} icon`} width="96" height="96" />
      <div>
        <span class="app-category">{tr.appCategories[app.category]}</span>
        <h1>{app.name[lang]}</h1>
        <p>{app.tagline[lang]}</p>
      </div>
    </div>
    <div class="store-actions">
      {app.googlePlayUrl && (
        <a href={app.googlePlayUrl} target="_blank" rel="noopener noreferrer" class="store-btn google-play">
          {tr.googlePlay}
        </a>
      )}
      {app.appStoreUrl && (
        <a href={app.appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn app-store">
          {tr.appStore}
        </a>
      )}
    </div>
  </div>
</section>

{app.id === 'ungyeol' && lang === 'ko' && (
  <section class="mini-tools-section">
    <div class="container">
      <h2>웹에서 먼저 체험하기</h2>
      <p class="mini-tools-subtitle">
        운결의 주요 기능을 무료 미니 풀이로 짧게 확인하고, 더 자세한 AI 풀이와 히스토리는 앱에서 이어보세요.
      </p>
      <div class="mini-tools-grid">
        {ungyeolServices.map((service) => (
          <a class="mini-tool-link" href={service.path}>
            <span>{service.eyebrow}</span>
            <strong>{service.navLabel}</strong>
            <p>{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{screenshots.length > 0 && (
  <section class="screenshots-section">
    <div class="container">
      <h2>{tr.screenshotsTitle}</h2>
      <div class="screenshots-row">
        {screenshots.map((screenshot) => (
          <figure class="screenshot">
            <img src={screenshot.src} alt={`${app.name[lang]} - ${screenshot.caption[lang]}`} loading="lazy" />
            <figcaption>{screenshot.caption[lang]}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<section class="detail-section">
  <div class="container detail-grid">
    <article class="detail-panel">
      <h2>{tr.keyFeaturesTitle}</h2>
      <ul class="feature-list">
        {app.features[lang].map((feature) => <li>{feature}</li>)}
      </ul>
    </article>
    <article class="detail-panel">
      <h2>{tr.recommendedForTitle}</h2>
      <ul class="feature-list">
        {app.recommendedFor[lang].map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

<section class="support-section">
  <div class="container support-layout">
    <div>
      <h2>{tr.supportAndPrivacyTitle}</h2>
      <p>{app.supportNote[lang]}</p>
    </div>
    <div class="support-links">
      <a href={`/${lang}/privacy/${app.id}/`}>{tr.privacyPolicy}</a>
      {app.supportsAccountDeletion && (
        <a href={`/${lang}/account-deletion/${app.id}/`}>{tr.accountDeletion}</a>
      )}
      <a href="mailto:kokomasoft@gmail.com">kokomasoft@gmail.com</a>
    </div>
  </div>
</section>

<style>
  .app-hero {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #101827;
    color: white;
  }

  .app-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(16, 24, 39, 0.96) 0%, rgba(16, 24, 39, 0.86) 46%, rgba(16, 24, 39, 0.36) 100%),
      linear-gradient(180deg, rgba(245, 174, 84, 0.16), rgba(15, 118, 110, 0.2));
  }

  .detail-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .backdrop-shot {
    position: absolute;
    width: min(235px, 38vw);
    aspect-ratio: 9 / 16;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 8px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.42);
  }

  .backdrop-shot-1 {
    right: max(9rem, calc((100vw - var(--max-width)) / 2 + 14rem));
    top: 3.5rem;
    transform: rotate(-7deg);
  }

  .backdrop-shot-2 {
    right: max(2rem, calc((100vw - var(--max-width)) / 2));
    top: 7rem;
    transform: rotate(6deg);
  }

  .app-hero .container {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: white;
  }

  .app-heading {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 850px;
  }

  .app-heading img {
    width: 96px;
    height: 96px;
    border-radius: 8px;
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.32);
    flex-shrink: 0;
  }

  .app-category {
    display: inline-block;
    color: #c7f9ea;
    font-size: 0.78rem;
    font-weight: 700;
    margin-bottom: 0.45rem;
    text-transform: uppercase;
  }

  h1 {
    max-width: 760px;
    color: white;
    font-size: clamp(2.7rem, 7vw, 5.8rem);
    font-weight: 800;
    line-height: 0.96;
    margin-bottom: 0.75rem;
  }

  .app-heading p {
    color: rgba(255, 255, 255, 0.76);
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.7;
    max-width: 680px;
  }

  .store-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .store-btn,
  .support-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.55rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
  }

  .store-btn.google-play {
    background: #f5ae54;
    color: #111827;
  }

  .store-btn.google-play:hover,
  .store-btn.app-store:hover {
    transform: translateY(-2px);
  }

  .store-btn.app-store {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: white;
    backdrop-filter: blur(14px);
  }

  .detail-section {
    padding: 5rem 0;
    background: var(--color-bg);
  }

  .mini-tools-section {
    padding: 5rem 0 0;
    background: var(--color-bg);
  }

  .mini-tools-subtitle {
    max-width: 720px;
    margin: -0.4rem auto 1.5rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.72;
  }

  .mini-tools-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .mini-tool-link {
    min-height: 190px;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .mini-tool-link:hover {
    border-color: rgba(15, 118, 110, 0.42);
    box-shadow: var(--shadow-soft);
    transform: translateY(-4px);
  }

  .mini-tool-link span {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.24rem 0.55rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.1);
    color: var(--color-primary);
    font-size: 0.74rem;
    font-weight: 850;
  }

  .mini-tool-link strong {
    display: block;
    color: var(--color-ink);
    font-size: 1.12rem;
    margin-bottom: 0.55rem;
  }

  .mini-tool-link p {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.62;
  }

  .screenshots-section {
    padding: 5rem 0 0;
    background: var(--color-bg);
  }

  .screenshots-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .screenshot {
    min-width: 0;
  }

  .screenshot img {
    display: block;
    width: 100%;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    box-shadow: var(--shadow-soft);
  }

  .screenshot figcaption {
    margin-top: 0.65rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 600;
    text-align: center;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .detail-panel {
    padding: 1.6rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.78);
  }

  h2 {
    color: var(--color-ink);
    font-size: clamp(1.7rem, 3vw, 2.35rem);
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1.2rem;
  }

  .feature-list {
    display: grid;
    gap: 0.75rem;
    list-style: none;
  }

  .feature-list li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    top: 0.68rem;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .support-section {
    padding: 4.5rem 0;
    background: #101827;
    color: white;
  }

  .support-section h2 {
    color: white;
  }

  .support-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: start;
  }

  .support-layout p {
    color: rgba(255, 255, 255, 0.7);
    max-width: 720px;
  }

  .support-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .support-links a {
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  .support-links a:hover {
    border-color: rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.14);
    color: white;
  }

  @media (max-width: 768px) {
    .app-hero {
      min-height: 680px;
      align-items: flex-start;
      padding-top: 3rem;
    }

    .app-heading,
    .support-layout {
      grid-template-columns: 1fr;
      flex-direction: column;
    }

    .app-heading {
      align-items: flex-start;
    }

    .app-heading img {
      width: 74px;
      height: 74px;
    }

    .backdrop-shot {
      width: 150px;
    }

    .backdrop-shot-1 {
      right: 42%;
      top: auto;
      bottom: 2.3rem;
    }

    .backdrop-shot-2 {
      right: 8%;
      top: auto;
      bottom: 3.8rem;
    }

    .detail-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .mini-tools-grid {
      grid-template-columns: 1fr;
    }

    .screenshots-row {
      display: flex;
      gap: 1rem;
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      overflow-x: auto;
      padding: 0 1.5rem 0.5rem;
      scroll-snap-type: x mandatory;
    }

    .screenshot {
      width: min(72vw, 280px);
      flex: 0 0 auto;
      scroll-snap-align: start;
    }

    .support-links {
      justify-content: flex-start;
    }
  }
</style>
