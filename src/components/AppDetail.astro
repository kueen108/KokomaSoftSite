---
import type { AppInfo } from '../i18n/apps';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { getUngyeolLandingCopy, getUngyeolServices } from '../i18n/ungyeolServices';

interface Props {
  app: AppInfo;
  lang: Lang;
}

const { app, lang } = Astro.props;
const tr = t(lang);
const screenshots = app.screenshots?.[lang] ?? app.screenshots?.en ?? [];
const ungyeolServices = getUngyeolServices(lang);
const ungyeolTools = getUngyeolLandingCopy(lang);
---

<section class="app-hero">
  <div class="detail-backdrop" aria-hidden="true">
    {screenshots.slice(0, 2).map((screenshot, index) => (
      <img class={`backdrop-shot backdrop-shot-${index + 1}`} src={screenshot.src} alt="" />
    ))}
  </div>
  <div class="container">
    <a class="back-link" href={`/${lang}/#apps`}>{tr.backToApps}</a>
    <div class="app-heading">
      <img src={app.iconUrl} alt={`${app.name[lang]} icon`} width="96" height="96" />
      <div>
        <span class="app-category">{tr.appCategories[app.category]}</span>
        <h1>{app.name[lang]}</h1>
        <p>{app.tagline[lang]}</p>
      </div>
    </div>
    <div class="store-actions">
      {app.webUrl && (
        <a href={app.webUrl} target="_blank" rel="noopener noreferrer" class="store-btn web-app">
          {tr.openWebApp}
        </a>
      )}
      {app.googlePlayUrl && (
        <a href={app.googlePlayUrl} target="_blank" rel="noopener noreferrer" class="store-btn google-play">
          {tr.googlePlay}
        </a>
      )}
      {app.appStoreUrl && (
        <a href={app.appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-btn app-store">
          {tr.appStore}
        </a>
      )}
      {lang === 'ko' && app.introVideoUrl && (
        <a href={app.introVideoUrl} target="_blank" rel="noopener noreferrer" class="store-btn video-link">
          {tr.appIntroVideo}
        </a>
      )}
    </div>
  </div>
</section>

{app.id === 'ungyeol' && (
  <section class="mini-tools-section">
    <div class="container">
      <h2>{ungyeolTools.detailTitle}</h2>
      <p class="mini-tools-subtitle">{ungyeolTools.detailSubtitle}</p>
      <div class="mini-tools-grid">
        {ungyeolServices.map((service) => (
          <a class="mini-tool-link" href={service.path}>
            <span>{service.eyebrow}</span>
            <strong>{service.navLabel}</strong>
            <p>{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{screenshots.length > 0 && (
  <section class="screenshots-section">
    <div class="container">
      <h2>{tr.screenshotsTitle}</h2>
      <div class="screenshots-row">
        {screenshots.map((screenshot) => (
          <figure class="screenshot">
            <img src={screenshot.src} alt={`${app.name[lang]} - ${screenshot.caption[lang]}`} loading="lazy" />
            <figcaption>{screenshot.caption[lang]}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}

<section class="detail-section">
  <div class="container detail-grid">
    <article class="detail-panel">
      <h2>{tr.keyFeaturesTitle}</h2>
      <ul class="feature-list">
        {app.features[lang].map((feature) => <li>{feature}</li>)}
      </ul>
    </article>
    <article class="detail-panel">
      <h2>{tr.recommendedForTitle}</h2>
      <ul class="feature-list">
        {app.recommendedFor[lang].map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

<section class="support-section">
  <div class="container support-layout">
    <div>
      <h2>{tr.supportAndPrivacyTitle}</h2>
      <p>{app.supportNote[lang]}</p>
    </div>
    <div class="support-links">
      <a href={`/${lang}/privacy/${app.id}/`}>{tr.privacyPolicy}</a>
      {app.supportsAccountDeletion && (
        <a href={`/${lang}/account-deletion/${app.id}/`}>{tr.accountDeletion}</a>
      )}
      <a href="mailto:kokomasoft@gmail.com">kokomasoft@gmail.com</a>
    </div>
  </div>
</section>

<style>
  .app-hero {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--ink-deep);
    color: #f1f0fa;
  }

  .app-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(10, 10, 20, 0.94) 0%, rgba(10, 10, 20, 0.82) 46%, rgba(10, 10, 20, 0.3) 100%),
      radial-gradient(60% 90% at 8% 0%, rgba(139, 92, 246, 0.28), transparent 60%),
      radial-gradient(50% 80% at 92% 100%, rgba(34, 211, 238, 0.18), transparent 60%),
      radial-gradient(40% 70% at 60% 10%, rgba(236, 72, 153, 0.16), transparent 60%);
  }

  .detail-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .backdrop-shot {
    position: absolute;
    width: min(235px, 38vw);
    aspect-ratio: 9 / 16;
    object-fit: cover;
    border: 1px solid var(--glass-border);
    border-radius: 1.4rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.55), 0 0 40px rgba(139, 92, 246, 0.18);
  }

  .backdrop-shot-1 {
    right: max(9rem, calc((100vw - var(--max-width)) / 2 + 14rem));
    top: 3.5rem;
    transform: rotate(-7deg);
  }

  .backdrop-shot-2 {
    right: max(2rem, calc((100vw - var(--max-width)) / 2));
    top: 7rem;
    transform: rotate(6deg);
  }

  .app-hero .container {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 2rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: white;
  }

  .app-heading {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    max-width: 850px;
  }

  .app-heading img {
    width: 96px;
    height: 96px;
    border-radius: 8px;
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.32);
    flex-shrink: 0;
  }

  .app-category {
    display: inline-block;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: #c4f6ff;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
    text-transform: uppercase;
  }

  h1 {
    max-width: 760px;
    color: #ffffff;
    font-size: clamp(2.7rem, 7vw, 5.8rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 0.96;
    margin-bottom: 0.75rem;
  }

  @supports (background-clip: text) or (-webkit-background-clip: text) {
    h1 {
      background: linear-gradient(110deg, #ffffff 0%, #d9d4ff 38%, #f3b3e0 70%, #a5ecfb 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
  }

  .app-heading p {
    color: #b9b6d4;
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.7;
    max-width: 680px;
  }

  .store-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .store-btn,
  .support-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.55rem 1.2rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s ease, border-color 0.25s ease;
  }

  .store-btn.google-play,
  .store-btn.web-app {
    background: var(--gradient-neon);
    color: #0a0a14;
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.4);
  }

  .store-btn.google-play:hover,
  .store-btn.web-app:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(236, 72, 153, 0.5);
  }

  .store-btn.app-store,
  .store-btn.video-link {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: #f1f0fa;
    backdrop-filter: blur(14px);
  }

  .store-btn.app-store:hover,
  .store-btn.video-link:hover {
    transform: translateY(-2px);
    border-color: rgba(34, 211, 238, 0.5);
    box-shadow: 0 0 18px rgba(34, 211, 238, 0.2);
  }

  .detail-section {
    padding: 5rem 0;
    background: var(--color-bg);
  }

  .mini-tools-section {
    padding: 5rem 0 0;
    background: var(--color-bg);
  }

  .mini-tools-subtitle {
    max-width: 720px;
    margin: -0.4rem auto 1.5rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.72;
  }

  .mini-tools-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .mini-tool-link {
    min-height: 190px;
    padding: 1.2rem;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.35s var(--ease-spring);
  }

  .mini-tool-link:hover {
    border-color: rgba(236, 72, 153, 0.5);
    box-shadow: 0 0 24px rgba(236, 72, 153, 0.16);
    transform: translateY(-4px);
  }

  .mini-tool-link span {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.24rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(236, 72, 153, 0.35);
    background: rgba(236, 72, 153, 0.14);
    color: #ffd1e8;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .mini-tool-link strong {
    display: block;
    color: var(--color-ink);
    font-size: 1.12rem;
    margin-bottom: 0.55rem;
  }

  .mini-tool-link p {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.62;
  }

  .screenshots-section {
    padding: 5rem 0 0;
    background: var(--color-bg);
  }

  .screenshots-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .screenshot {
    min-width: 0;
  }

  .screenshot img {
    display: block;
    width: 100%;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    border: 1px solid var(--glass-border);
    border-radius: 1.4rem;
    background: rgba(255, 255, 255, 0.04);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
  }

  .screenshot figcaption {
    margin-top: 0.65rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 600;
    text-align: center;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .detail-panel {
    padding: 1.6rem;
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.04);
  }

  h2 {
    color: var(--color-ink);
    font-size: clamp(1.7rem, 3vw, 2.35rem);
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1.2rem;
  }

  .feature-list {
    display: grid;
    gap: 0.75rem;
    list-style: none;
  }

  .feature-list li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    top: 0.68rem;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .support-section {
    padding: 4.5rem 0;
    background:
      radial-gradient(70% 120% at 100% 0%, rgba(139, 92, 246, 0.12), transparent 60%),
      var(--color-bg-alt);
    color: var(--color-text);
  }

  .support-section h2 {
    color: var(--color-ink);
  }

  .support-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: start;
  }

  .support-layout p {
    color: var(--color-text-muted);
    max-width: 720px;
  }

  .support-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .support-links a {
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: #f1f0fa;
  }

  .support-links a:hover {
    border-color: rgba(34, 211, 238, 0.5);
    background: rgba(255, 255, 255, 0.09);
    box-shadow: 0 0 16px rgba(34, 211, 238, 0.18);
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .app-hero {
      min-height: 680px;
      align-items: flex-start;
      padding-top: 3rem;
    }

    .app-heading,
    .support-layout {
      grid-template-columns: 1fr;
      flex-direction: column;
    }

    .app-heading {
      align-items: flex-start;
    }

    .app-heading img {
      width: 74px;
      height: 74px;
    }

    .backdrop-shot {
      width: 150px;
    }

    .backdrop-shot-1 {
      right: 42%;
      top: auto;
      bottom: 2.3rem;
    }

    .backdrop-shot-2 {
      right: 8%;
      top: auto;
      bottom: 3.8rem;
    }

    .detail-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .mini-tools-grid {
      grid-template-columns: 1fr;
    }

    .screenshots-row {
      display: flex;
      gap: 1rem;
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      overflow-x: auto;
      padding: 0 1.5rem 0.5rem;
      scroll-snap-type: x mandatory;
    }

    .screenshot {
      width: min(72vw, 280px);
      flex: 0 0 auto;
      scroll-snap-align: start;
    }

    .support-links {
      justify-content: flex-start;
    }
  }
</style>
